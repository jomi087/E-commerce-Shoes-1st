<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Fashion Feet</title>
    <!-- bootstrap and its icon -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Swwet Alert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <!-- tostify Css -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        body {
            background-color: #f5f5f5;
            font-family: Arial, sans-serif;
            font-size: 14px;
        }

        .navbar-nav {
            flex: 1;
            justify-content: space-evenly;
        }

        .navbar-icons {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
        }

        .edit-icon {
            position: absolute;
            right: 20px;
            top: 20px;
            cursor: pointer;
        }

        .invoice-link {
            color: black;
            text-decoration: none;
            padding-left: 10px;
            font-size: 21px;
        }

        .invoice-link:hover {
            color: #120db7;
        }

        .hidden {
            display: none;
        }

        /* Profile content area */
        .profile-card {
            position: relative;
            padding: 2rem 1.5rem 1.5rem;
            border-radius: 0.5rem;
            background: #fff;
        }

        /* Stack profile pic + info vertically on mobile, row on md+ */
        .profile-body {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1.25rem;
            text-align: center;
        }

        @media (min-width: 768px) {
            .profile-body {
                flex-direction: row;
                align-items: center;
                text-align: left;
            }
        }

        .profile-body img {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 50%;
        }

        .profile-info p {
            margin-bottom: 0.4rem;
        }

        /* Sidebar: collapsible on mobile */
        .sidebar-toggle {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            padding: 0.65rem 1rem;
            cursor: pointer;
            font-weight: 600;
            width: 100%;
            margin-bottom: 0.5rem;
        }

        .sidebar-toggle .bi {
            transition: transform 0.2s;
        }

        .sidebar-toggle.collapsed .bi {
            transform: rotate(-90deg);
        }

        @media (min-width: 768px) {
            .sidebar-toggle {
                display: none;
            }

            #sidebarMenu {
                display: block !important;
            }
        }

        /* Ensure list group items are tappable on mobile */
        .list-group-item {
            padding: 0.75rem 1rem;
        }

        /* Navbar icons gap on small screens */
        @media (max-width: 400px) {
            .navbar-icons {
                gap: 8px;
            }
        }
    </style>
</head>

<body>