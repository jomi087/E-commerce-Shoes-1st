<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fashion Feet — Edit Category</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --bg: #0f0f0f; --surface: #1a1a1a; --surface2: #2a2a2a;
            --border: #2a2a2a; --border2: #3a3a3a;
            --cream: #f0e6d3; --muted: #999; --dim: #666;
            --gold1: #c9a96e; --gold2: #a8813d;
            --error: #e05f5f; --success: #4caf7d;
            --sidebar-w: 220px;
        }
        html { height: 100%; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--cream);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* NAVBAR */
        .navbar {
            position: sticky; top: 0; z-index: 100;
            background: var(--surface); border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            padding: .85rem 1.5rem; gap: 1rem; flex-shrink: 0;
        }
        .navbar-brand { font-family: 'Playfair Display', serif; font-size: 1.45rem; color: var(--cream); letter-spacing: 1px; white-space: nowrap; text-decoration: none; }
        .navbar-right { display: flex; align-items: center; gap: 1rem; }
        .navbar-badge { font-size: .65rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); border: 1px solid var(--border2); padding: .25rem .65rem; border-radius: 20px; }
        .logout-btn { font-size: .75rem; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); text-decoration: none; padding: .4rem .9rem; border: 1px solid var(--border2); border-radius: 6px; transition: color .2s, border-color .2s; display: flex; align-items: center; gap: .4rem; }
        .logout-btn:hover { color: var(--gold1); border-color: var(--gold1); }
        .hamburger { display: none; background: none; border: 1px solid var(--border2); border-radius: 6px; color: var(--muted); font-size: 1.2rem; padding: .3rem .55rem; cursor: pointer; }

        /* LAYOUT */
        .layout { display: flex; flex: 1; }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            padding: 1.5rem 1rem; gap: .35rem;
            flex-shrink: 0;
            position: sticky; top: 57px;
            height: calc(100vh - 57px);
            overflow-y: auto;
            transition: transform .3s ease;
        }
        .sidebar-label { font-size: .6rem; letter-spacing: 2.5px; text-transform: uppercase; color: var(--dim); padding: .5rem .65rem .2rem; margin-top: .5rem; }
        .nav-link { display: flex; align-items: center; gap: .65rem; padding: .65rem .85rem; border-radius: 8px; color: var(--muted); text-decoration: none; font-size: .86rem; font-weight: 500; transition: background .2s, color .2s; }
        .nav-link i { font-size: 1rem; width: 1.1rem; text-align: center; }
        .nav-link:hover { background: var(--surface2); color: var(--cream); }
        .nav-link.active { background: linear-gradient(135deg, rgba(201,169,110,.18), rgba(168,129,61,.1)); color: var(--gold1); border: 1px solid rgba(201,169,110,.2); }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 90; }

        /* MAIN */
        .main {
            flex: 1; padding: 2rem 1.75rem;
            display: flex; flex-direction: column; gap: 1.75rem;
            min-width: 0;
        }

        /* PAGE HEADER */
        .page-header { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
        .back-btn {
            display: inline-flex; align-items: center; gap: .45rem;
            padding: .45rem 1rem;
            background: transparent;
            border: 1px solid var(--border2);
            border-radius: 8px;
            color: var(--muted);
            text-decoration: none;
            font-size: .8rem; font-weight: 500;
            letter-spacing: .5px;
            transition: color .2s, border-color .2s, background .2s;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
        }
        .back-btn:hover { color: var(--gold1); border-color: var(--gold1); background: rgba(201,169,110,.07); }
        .page-title { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 700; color: var(--cream); }

        /* BREADCRUMB */
        .breadcrumb {
            display: flex; align-items: center; gap: .5rem;
            font-size: .72rem; color: var(--dim); letter-spacing: .5px;
        }
        .breadcrumb a { color: var(--muted); text-decoration: none; transition: color .2s; }
        .breadcrumb a:hover { color: var(--gold1); }
        .breadcrumb .sep { color: var(--dim); font-size: .65rem; }
        .breadcrumb .current { color: var(--gold1); }

        /* FORM CARD */
        .form-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            max-width: 680px;
            animation: fadeUp .45s ease both;
        }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

        .card-header {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: .75rem;
        }
        .card-header-icon {
            width: 36px; height: 36px; border-radius: 8px;
            background: linear-gradient(135deg, rgba(201,169,110,.2), rgba(168,129,61,.1));
            border: 1px solid rgba(201,169,110,.2);
            display: flex; align-items: center; justify-content: center;
            color: var(--gold1); font-size: 1rem; flex-shrink: 0;
        }
        .card-title { font-family: 'Playfair Display', serif; font-size: 1.05rem; color: var(--cream); }
        .card-subtitle { font-size: .74rem; color: var(--muted); margin-top: .1rem; }

        /* FORM */
        .form-body { padding: 1.75rem 1.5rem; }
        .form-group { display: flex; flex-direction: column; gap: .45rem; margin-bottom: 1.4rem; }
        .form-label { font-size: .72rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); font-weight: 600; }
        .form-input, .form-textarea {
            background: #111;
            border: 1px solid #444;
            border-radius: 8px;
            padding: .7rem .95rem;
            color: var(--cream);
            font-family: 'DM Sans', sans-serif;
            font-size: .875rem;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            width: 100%;
        }
        .form-textarea { resize: vertical; min-height: 110px; }
        .form-input::placeholder, .form-textarea::placeholder { color: var(--dim); }
        .form-input:focus, .form-textarea:focus {
            border-color: var(--gold1);
            box-shadow: 0 0 0 3px rgba(201,169,110,.12);
        }
        .field-error { font-size: .72rem; color: var(--error); min-height: 1.1em; display: flex; align-items: center; gap: .3rem; }
        .server-error {
            background: rgba(224,95,95,.08);
            border: 1px solid rgba(224,95,95,.25);
            border-radius: 8px;
            padding: .65rem 1rem;
            color: var(--error);
            font-size: .8rem;
            display: flex; align-items: center; gap: .5rem;
            margin-bottom: 1.25rem;
        }

        /* HINT */
        .field-hint { font-size: .7rem; color: var(--dim); margin-top: -.1rem; }

        /* DIVIDER */
        .form-divider { border: none; border-top: 1px solid var(--border); margin: .25rem 0 1.25rem; }

        /* FOOTER */
        .form-footer {
            display: flex; justify-content: space-between; align-items: center;
            gap: 1rem; flex-wrap: wrap;
            padding-top: 1.25rem;
            border-top: 1px solid var(--border);
        }
        .cancel-btn {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .62rem 1.2rem;
            background: transparent;
            border: 1px solid var(--border2);
            border-radius: 8px;
            color: var(--muted);
            font-family: 'DM Sans', sans-serif;
            font-size: .8rem; font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: color .2s, border-color .2s, background .2s;
        }
        .cancel-btn:hover { color: var(--cream); border-color: #555; background: var(--surface2); }
        .submit-btn {
            display: inline-flex; align-items: center; gap: .5rem;
            padding: .65rem 1.6rem;
            background: linear-gradient(135deg, var(--gold1), var(--gold2));
            border: none; border-radius: 8px;
            color: #0f0f0f; font-family: 'DM Sans', sans-serif;
            font-size: .82rem; font-weight: 700; letter-spacing: 1px;
            text-transform: uppercase; cursor: pointer;
            transition: opacity .2s, transform .15s;
        }
        .submit-btn:hover { opacity: .88; transform: translateY(-1px); }
        .submit-btn:active { transform: translateY(0); }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .hamburger { display: block; }
            .sidebar {
                position: fixed; top: 0; left: 0; bottom: 0;
                z-index: 95; height: 100vh;
                transform: translateX(-100%);
                padding-top: 4.5rem;
            }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { padding: 1.25rem 1rem; }
        }
        @media (max-width: 500px) { .navbar-badge { display: none; } }
    </style>
</head>
<body>

    <header class="navbar">
        <div style="display:flex;align-items:center;gap:.85rem;">
            <button class="hamburger" id="hamburgerBtn" aria-label="Menu"><i class="bi bi-list"></i></button>
            <a class="navbar-brand" href="#">Fashion Feet</a>
        </div>
        <div class="navbar-right">
            <span class="navbar-badge">Admin Portal</span>
            <a href="/admin/logout" class="logout-btn"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </div>
    </header>

    <div class="layout">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="sidebar">
            <span class="sidebar-label">Main</span>
            <a class="nav-link" href="/admin/dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
            <a class="nav-link" href="/admin/customer"><i class="bi bi-people"></i> Customers</a>
            <a class="nav-link" href="/admin/product"><i class="bi bi-box-seam"></i> Products</a>
            <a class="nav-link" href="/admin/orderManagement"><i class="bi bi-basket3"></i> Orders</a>
            <span class="sidebar-label">Management</span>
            <a class="nav-link" href="/admin/couponManagement"><i class="bi bi-ticket-perforated"></i> Coupons</a>
            <a class="nav-link" href="/admin/salesReport"><i class="bi bi-bar-chart-line"></i> Sales Report</a>
            <a class="nav-link active" href="/admin/category"><i class="bi bi-tag"></i> Categories</a>
        </aside>

        <main class="main">

            <!-- Page Header -->
            <div>
                <!-- <div class="breadcrumb" style="margin-bottom:.75rem;">
                    <a href="/admin/dashboard">Dashboard</a>
                    <span class="sep"><i class="bi bi-chevron-right"></i></span>
                    <a href="/admin/category">Categories</a>
                    <span class="sep"><i class="bi bi-chevron-right"></i></span>
                    <span class="current">Edit</span>
                </div> -->
                <div class="page-header">
                    <a href="/admin/category" class="back-btn">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <h1 class="page-title">Edit Category</h1>
                </div>
            </div>

            <!-- Edit Form Card -->
            <div class="form-card">
                <div class="card-header">
                    <div class="card-header-icon"><i class="bi bi-pencil-square"></i></div>
                    <div>
                        <div class="card-title">Update Details</div>
                        <div class="card-subtitle">Changes will apply to all products in this category</div>
                    </div>
                </div>

                <div class="form-body">
                    <% if (locals.alert) { %>
                        <div class="server-error">
                            <i class="bi bi-exclamation-circle-fill"></i>
                            <%= locals.alert %>
                        </div>
                    <% } %>

                    <form method="post" action="/admin/editCategory" onsubmit="return validateForm()">
                        <input type="hidden" name="id" value="<%= category._id %>">

                        <div class="form-group">
                            <label class="form-label" for="category-Name">Category Name</label>
                            <input
                                type="text"
                                id="category-Name"
                                name="categoryName"
                                class="form-input"
                                value="<%= category.name %>"
                                placeholder="e.g. SNEAKERS"
                                autocomplete="off"
                            >
                            <span class="field-hint">Uppercase letters only (A–Z)</span>
                            <span class="field-error" id="categoryName-error"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="product-description">Description</label>
                            <textarea
                                id="product-description"
                                name="productDescription"
                                class="form-textarea"
                                placeholder="Enter a description, or type N/A"
                            ><%= category.description %></textarea>
                            <span class="field-error" id="description-error"></span>
                        </div>

                        <div class="form-footer">
                            <a href="/admin/category" class="cancel-btn">
                                <i class="bi bi-x"></i> Cancel
                            </a>
                            <button type="submit" class="submit-btn">
                                <i class="bi bi-check2"></i> Update Category
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </main>
    </div>

    <script>
        // Sidebar toggle
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const hamburger = document.getElementById('hamburgerBtn');
        hamburger.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
        overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });

        function validateForm() {
            let isValid = true;
            const categoryInput = document.getElementById('category-Name').value.trim();
            const productdescription = document.getElementById('product-description').value.trim();
            const categoryNameError = document.getElementById('categoryName-error');
            const descriptionError = document.getElementById('description-error');

            categoryNameError.textContent = '';
            descriptionError.textContent = '';

            if (!categoryInput) {
                categoryNameError.innerHTML = '<i class="bi bi-exclamation-circle"></i> Category name is required';
                isValid = false;
            } else if (!/^[A-Z]+$/.test(categoryInput)) {
                categoryNameError.innerHTML = '<i class="bi bi-exclamation-circle"></i> Name should only contain uppercase alphabetic characters';
                isValid = false;
            }
            if (!productdescription) {
                descriptionError.innerHTML = '<i class="bi bi-exclamation-circle"></i> Description is required (enter N/A if not applicable)';
                isValid = false;
            }
            return isValid;
        }
    </script>
</body>
</html>
