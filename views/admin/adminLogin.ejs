<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fashion Feet — Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; cursor: default !important; }
        input, textarea, select, button, a { cursor: pointer !important; }
        input[type="text"], input[type="email"], input[type="password"] { cursor: text !important; }

        :root {
            --bg:      #0f0f0f;
            --card:    #1a1a1a;
            --border:  #2a2a2a;
            --border2: #333;
            --cream:   #f0e6d3;
            --muted:   #999;
            --dim:     #666;
            --gold1:   #c9a96e;
            --gold2:   #a8813d;
            --error:   #e05f5f;
        }

        html, body { height: 100%; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--cream);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Navbar ── */
        nav {
            background: var(--bg);
            border-bottom: 1px solid var(--border2);
            padding: .75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .nav-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.55rem;
            color: var(--cream);
            text-decoration: none;
            letter-spacing: 1px;
        }

        .nav-badge {
            font-family: 'DM Sans', sans-serif;
            font-size: .68rem;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--muted);
            border: 1px solid var(--border2);
            padding: .28rem .7rem;
            border-radius: 6px;
        }

        /* ── Page wrapper ── */
        main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2.5rem 1rem;
        }

        /* ── Card ── */
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2.5rem 2.75rem;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 8px 48px rgba(0,0,0,.5);
            animation: fadeUp .4s ease both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Card header ── */
        .card-eyebrow {
            font-size: .68rem;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--gold1);
            margin-bottom: .5rem;
        }

        .card h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            color: var(--cream);
            margin-bottom: .2rem;
        }

        .subtitle {
            color: var(--dim);
            font-size: .82rem;
            letter-spacing: .5px;
            margin-bottom: 1.75rem;
        }

        /* ── Server error ── */
        .server-error {
            font-size: .83rem;
            color: var(--error);
            text-align: center;
            margin-bottom: 1rem;
            display: none;
        }
        .server-error.visible { display: block; }

        /* ── Form ── */
        .field { margin-bottom: 1.2rem; }

        .field label {
            display: block;
            font-size: .75rem;
            font-weight: 500;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: .4rem;
        }

        .field input {
            width: 100%;
            background: #111;
            border: 1px solid var(--border2);
            border-radius: 8px;
            color: var(--cream);
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
            padding: .65rem .9rem;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }

        .field input::placeholder { color: #444; }

        .field input:focus {
            border-color: var(--gold1);
            box-shadow: 0 0 0 3px rgba(201,169,110,.12);
        }

        .field input.is-invalid {
            border-color: var(--error);
            box-shadow: 0 0 0 3px rgba(224,95,95,.10);
        }

        .field-error {
            font-size: .78rem;
            color: var(--error);
            min-height: 1.1rem;
            margin-top: .3rem;
        }

        /* ── Forgot ── */
        .forgot-row {
            text-align: right;
            margin-bottom: 1.4rem;
            margin-top: -.2rem;
        }

        .forgot-row a {
            font-size: .8rem;
            color: var(--gold1);
            text-decoration: none;
        }

        .forgot-row a:hover { text-decoration: underline; }

        /* ── Submit ── */
        .btn-submit {
            width: 100%;
            padding: .8rem;
            background: linear-gradient(135deg, var(--gold1), var(--gold2));
            border: none;
            border-radius: 10px;
            color: #0f0f0f;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
            font-size: .88rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: opacity .2s, transform .15s;
        }

        .btn-submit:hover {
            opacity: .87;
            transform: translateY(-1px);
            cursor: pointer !important;
        }

        /* ── Footer ── */
        footer {
            text-align: center;
            padding: 1.2rem;
            font-size: .68rem;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--border2);
        }
    </style>
</head>
<body>

    <nav>
        <a class="nav-brand" href="/">Fashion Feet</a>
        <span class="nav-badge">Admin Portal</span>
    </nav>

    <main>
        <div class="card">
            <p class="card-eyebrow">Secure Access</p>
            <h1>Welcome back</h1>
            <p class="subtitle">Sign in to your admin account</p>

            <p class="server-error" id="serverError"><%=locals.message%></p>

            <form id="loginForm" action="/admin/" method="post" novalidate>

                <div class="field">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" placeholder="you@example.com" autocomplete="email">
                    <div class="field-error" id="emailError"></div>
                </div>

                <div class="field">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" placeholder="Enter your password" autocomplete="current-password">
                    <div class="field-error" id="passwordError"></div>
                </div>

                <div class="forgot-row">
                    <a href="/forgot-password">Forgot password?</a>
                </div>

                <button type="submit" class="btn-submit">Sign In</button>
            </form>
        </div>
    </main>

    <footer>© 2025 Fashion Feet</footer>

    <script>
        (function () {
            const el = document.getElementById('serverError');
            if (el && el.textContent.trim() && !el.textContent.includes('locals.message')) {
                el.classList.add('visible');
            }
        })();

        document.getElementById('loginForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const email    = document.getElementById('email');
            const password = document.getElementById('password');
            const emailErr = document.getElementById('emailError');
            const passErr  = document.getElementById('passwordError');

            emailErr.textContent = '';
            passErr.textContent  = '';
            email.classList.remove('is-invalid');
            password.classList.remove('is-invalid');

            let valid = true;

            if (!email.value.trim()) {
                emailErr.textContent = 'Email is required.';
                email.classList.add('is-invalid');
                valid = false;
            } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) {
                emailErr.textContent = 'Invalid email format.';
                email.classList.add('is-invalid');
                valid = false;
            }

            if (!password.value.trim()) {
                passErr.textContent = 'Password is required.';
                password.classList.add('is-invalid');
                valid = false;
            } else if (password.value.trim().length < 6) {
                passErr.textContent = 'Password must be at least 6 characters.';
                password.classList.add('is-invalid');
                valid = false;
            }

            if (valid) this.submit();
        });
    </script>
</body>
</html>