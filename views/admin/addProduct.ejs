<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fashion Feet — Add Product</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:       #0f0f0f;
            --surface:  #1a1a1a;
            --surface2: #222222;
            --border:   #2a2a2a;
            --border2:  #333;
            --cream:    #f0e6d3;
            --muted:    #999;
            --dim:      #555;
            --gold1:    #c9a96e;
            --gold2:    #a8813d;
            --error:    #e05f5f;
            --success:  #4caf7d;
            --sidebar-w: 220px;
        }

        html, body { height: 100%; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--cream);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ── Navbar ── */
        .navbar {
            position: sticky; top: 0; z-index: 100;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            padding: .85rem 1.5rem; gap: 1rem;
        }
        .navbar-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem; color: var(--cream);
            letter-spacing: 1px; text-decoration: none;
        }
        .navbar-right { display: flex; align-items: center; gap: 1rem; }
        .navbar-badge {
            font-size: .65rem; letter-spacing: 2px; text-transform: uppercase;
            color: var(--muted); border: 1px solid var(--border2);
            padding: .25rem .65rem; border-radius: 20px;
        }
        .logout-btn {
            font-size: .75rem; font-weight: 500; letter-spacing: 1.5px;
            text-transform: uppercase; color: var(--muted); text-decoration: none;
            padding: .4rem .9rem; border: 1px solid var(--border2); border-radius: 6px;
            transition: color .2s, border-color .2s;
            display: flex; align-items: center; gap: .4rem;
        }
        .logout-btn:hover { color: var(--gold1); border-color: var(--gold1); }
        .hamburger {
            display: none; background: none; border: 1px solid var(--border2);
            border-radius: 6px; color: var(--muted); font-size: 1.2rem;
            padding: .3rem .55rem; cursor: pointer;
        }

        /* ── Layout ── */
        .layout { display: flex; flex: 1; overflow: hidden; }

        /* ── Sidebar ── */
        .sidebar {
            width: var(--sidebar-w); background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            padding: 1.5rem 1rem; gap: .35rem;
            flex-shrink: 0; transition: transform .3s ease;
        }
        .sidebar-label {
            font-size: .6rem; letter-spacing: 2.5px; text-transform: uppercase;
            color: var(--dim); padding: .5rem .65rem .2rem; margin-top: .5rem;
        }
        .nav-link {
            display: flex; align-items: center; gap: .65rem;
            padding: .65rem .85rem; border-radius: 8px;
            color: var(--muted); text-decoration: none;
            font-size: .86rem; font-weight: 500;
            transition: background .2s, color .2s;
        }
        .nav-link i { font-size: 1rem; width: 1.1rem; text-align: center; }
        .nav-link:hover { background: var(--surface2); color: var(--cream); }
        .nav-link.active {
            background: linear-gradient(135deg, rgba(201,169,110,.18), rgba(168,129,61,.1));
            color: var(--gold1); border: 1px solid rgba(201,169,110,.2);
        }
        .sidebar-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.6); z-index: 90;
        }

        /* ── Main ── */
        .main {
            flex: 1; overflow-y: auto;
            padding: 2rem 1.75rem;
            display: flex; flex-direction: column; gap: 1.5rem;
        }

        /* ── Page header ── */
        .page-header {
            display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
            justify-content: space-between;
        }
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem; font-weight: 700; color: var(--cream);
        }
        .back-btn {
            display: inline-flex; align-items: center; gap: .4rem;
            font-size: .78rem; font-weight: 500; letter-spacing: 1px;
            text-transform: uppercase; color: var(--muted);
            text-decoration: none; padding: .4rem .9rem;
            border: 1px solid var(--border2); border-radius: 6px;
            transition: color .2s, border-color .2s;
        }
        .back-btn:hover { color: var(--gold1); border-color: var(--gold1); }

        /* ── Server message ── */
        .server-msg {
            background: rgba(224,95,95,.08);
            border: 1px solid rgba(224,95,95,.25);
            border-left: 3px solid var(--error);
            border-radius: 8px; color: var(--error);
            font-size: .85rem; padding: .75rem 1rem;
        }

        /* ── Form card ── */
        .form-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px; padding: 2rem;
            animation: fadeUp .4s ease both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .form-section-title {
            font-size: .65rem; font-weight: 600;
            letter-spacing: 2.5px; text-transform: uppercase;
            color: var(--dim); margin-bottom: 1.25rem;
            padding-bottom: .6rem; border-bottom: 1px solid var(--border);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.1rem 1.5rem;
        }

        .form-group { display: flex; flex-direction: column; gap: .4rem; }
        .form-group.full { grid-column: 1 / -1; }

        .form-label {
            font-size: .7rem; font-weight: 600;
            letter-spacing: 1.5px; text-transform: uppercase;
            color: var(--muted);
        }

        .form-control, .form-select {
            background: #111;
            border: 1px solid var(--border2);
            border-radius: 8px;
            color: var(--cream);
            font-family: 'DM Sans', sans-serif;
            font-size: .9rem;
            padding: .65rem .9rem;
            outline: none;
            width: 100%;
            transition: border-color .2s, box-shadow .2s;
            appearance: none;
            -webkit-appearance: none;
        }
        .form-control::placeholder { color: #444; }
        .form-control:focus, .form-select:focus {
            border-color: var(--gold1);
            box-shadow: 0 0 0 3px rgba(201,169,110,.12);
        }
        .form-control.is-invalid, .form-select.is-invalid {
            border-color: var(--error);
            box-shadow: 0 0 0 3px rgba(224,95,95,.09);
        }

        /* custom select arrow */
        .select-wrap { position: relative; }
        .select-wrap::after {
            content: '\F282';
            font-family: 'bootstrap-icons';
            position: absolute; right: .9rem; top: 50%; transform: translateY(-50%);
            color: var(--muted); pointer-events: none; font-size: .85rem;
        }

        textarea.form-control { resize: vertical; min-height: 90px; }

        .field-error {
            font-size: .72rem; color: var(--error);
            min-height: 1rem;
        }

        /* ── Section divider ── */
        .section-gap { margin-top: 1.75rem; }

        /* ── Image upload zone ── */
        .upload-zone {
            border: 2px dashed var(--border2);
            border-radius: 10px;
            padding: 1.75rem;
            text-align: center;
            cursor: pointer;
            transition: border-color .2s, background .2s;
            position: relative;
        }
        .upload-zone:hover { border-color: var(--gold1); background: rgba(201,169,110,.03); }
        .upload-zone input[type="file"] {
            position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
        }
        .upload-icon { font-size: 2rem; color: var(--dim); margin-bottom: .5rem; }
        .upload-text { font-size: .85rem; color: var(--muted); }
        .upload-hint { font-size: .72rem; color: var(--dim); margin-top: .25rem; }

        /* ── Cropper area ── */
        .cropper-area {
            display: none;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1rem;
            margin-top: 1rem;
            position: relative;
        }
        .cropper-area.visible { display: block; }

        #currentImagePreview {
            max-height: 300px;
            width: 100%;
            object-fit: contain;
            border-radius: 6px;
            display: block;
        }

        .crop-actions {
            display: flex; gap: .75rem; margin-top: 1rem;
            flex-wrap: wrap;
        }

        .btn-crop {
            display: inline-flex; align-items: center; gap: .4rem;
            background: linear-gradient(135deg, var(--gold1), var(--gold2));
            border: none; border-radius: 8px;
            color: #0f0f0f; font-family: 'DM Sans', sans-serif;
            font-weight: 700; font-size: .8rem; letter-spacing: 1px;
            text-transform: uppercase; padding: .55rem 1.25rem; cursor: pointer;
            transition: opacity .2s;
        }
        .btn-crop:hover { opacity: .85; }

        /* ── Cropped previews ── */
        .cropped-grid {
            display: flex; flex-wrap: wrap; gap: .75rem; margin-top: 1rem;
        }

        .cropped-thumb {
            position: relative; width: 100px; height: 100px;
            border-radius: 8px; overflow: hidden;
            border: 1px solid var(--border2);
        }
        .cropped-thumb img {
            width: 100%; height: 100%; object-fit: cover; display: block;
        }
        .remove-thumb {
            position: absolute; top: 4px; right: 4px;
            background: rgba(15,15,15,.8); border: none; border-radius: 4px;
            color: var(--error); width: 22px; height: 22px;
            display: flex; align-items: center; justify-content: center;
            font-size: .75rem; cursor: pointer; transition: background .2s;
        }
        .remove-thumb:hover { background: var(--error); color: #fff; }

        /* ── Submit area ── */
        .form-footer {
            display: flex; justify-content: flex-end; gap: .75rem;
            margin-top: 2rem; padding-top: 1.25rem;
            border-top: 1px solid var(--border);
            flex-wrap: wrap;
        }

        .btn-cancel {
            display: inline-flex; align-items: center; gap: .4rem;
            font-size: .8rem; font-weight: 500; letter-spacing: 1px;
            text-transform: uppercase; color: var(--muted);
            text-decoration: none; padding: .65rem 1.4rem;
            border: 1px solid var(--border2); border-radius: 8px;
            transition: color .2s, border-color .2s;
        }
        .btn-cancel:hover { color: var(--cream); border-color: var(--cream); }

        .btn-submit {
            display: inline-flex; align-items: center; gap: .4rem;
            background: linear-gradient(135deg, var(--gold1), var(--gold2));
            border: none; border-radius: 8px;
            color: #0f0f0f; font-family: 'DM Sans', sans-serif;
            font-weight: 700; font-size: .82rem; letter-spacing: 1.5px;
            text-transform: uppercase; padding: .7rem 1.75rem; cursor: pointer;
            transition: opacity .2s, transform .15s;
        }
        .btn-submit:hover { opacity: .87; transform: translateY(-1px); }

        /* ── Responsive ── */
        @media (max-width: 768px) {
            :root { --sidebar-w: 240px; }
            .hamburger { display: block; }
            .sidebar {
                position: fixed; top: 0; left: 0; bottom: 0;
                z-index: 95; transform: translateX(-100%); padding-top: 4.5rem;
            }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { padding: 1.25rem 1rem; }
            .form-grid { grid-template-columns: 1fr; }
            .form-group.full { grid-column: 1; }
            .navbar-badge { display: none; }
        }
    </style>
</head>
<body>

    <!-- ── NAVBAR ── -->
    <header class="navbar">
        <div style="display:flex;align-items:center;gap:.85rem;">
            <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
                <i class="bi bi-list"></i>
            </button>
            <a class="navbar-brand" href="#">Fashion Feet</a>
        </div>
        <div class="navbar-right">
            <span class="navbar-badge">Admin Portal</span>
            <a href="/admin/logout" class="logout-btn">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>
    </header>

    <div class="layout">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- ── SIDEBAR ── -->
        <aside class="sidebar" id="sidebar">
            <span class="sidebar-label">Main</span>
            <a class="nav-link" href="/admin/dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
            <a class="nav-link" href="/admin/customer"><i class="bi bi-people"></i> Customers</a>
            <a class="nav-link active" href="/admin/product"><i class="bi bi-box-seam"></i> Products</a>
            <a class="nav-link" href="/admin/orderManagement"><i class="bi bi-basket3"></i> Orders</a>
            <span class="sidebar-label">Management</span>
            <a class="nav-link" href="/admin/couponManagement"><i class="bi bi-ticket-perforated"></i> Coupons</a>
            <a class="nav-link" href="/admin/salesReport"><i class="bi bi-bar-chart-line"></i> Sales Report</a>
            <a class="nav-link" href="/admin/category"><i class="bi bi-tag"></i> Categories</a>
        </aside>

        <!-- ── MAIN ── -->
        <main class="main">

            <div class="page-header">
                <h1 class="page-title">Add Product</h1>
                <a href="/admin/product" class="back-btn">
                    <i class="bi bi-arrow-left"></i> Back to Products
                </a>
            </div>

            <% if (locals.message) { %>
            <div class="server-msg"><i class="bi bi-exclamation-circle"></i> <%= locals.message %></div>
            <% } %>

            <div class="form-card">
                <form action="/admin/addProduct" method="post" enctype="multipart/form-data" onsubmit="return validateForm()">

                    <!-- Basic Info -->
                    <p class="form-section-title">Basic Information</p>
                    <div class="form-grid">

                        <div class="form-group full">
                            <label class="form-label">Product Name</label>
                            <input type="text" id="productName" name="Pname" class="form-control" placeholder="e.g. Classic White Sneaker">
                            <span class="field-error" id="productNameError"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Category</label>
                            <div class="select-wrap">
                                <select name="Pcategory" id="category" class="form-select">
                                    <option value="">Select category</option>
                                    <% category.forEach((cat) => { %>
                                        <option value="<%= cat._id %>"><%= cat.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <span class="field-error" id="categoryError"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Size</label>
                            <div class="select-wrap">
                                <select id="size" name="Psize" class="form-select">
                                    <option value="">Select size</option>
                                    <option value="1c">3–3.5 Years (1c)</option>
                                    <option value="2c">3.5–4 Years (2c)</option>
                                    <option value="3c">4–4.5 Years (3c)</option>
                                    <option value="4c">4.5–5 Years (4c)</option>
                                    <option value="5c">5–5.5 Years (5c)</option>
                                    <option value="6c">5.5–6 Years (6c)</option>
                                    <option value="1">6–7 Years (1)</option>
                                    <option value="2">7–8 Years (2)</option>
                                    <option value="3">8–9 Years (3)</option>
                                    <option value="4">9–10 Years (4)</option>
                                    <option value="5">10–12 Years (5)</option>
                                    <option value="6">6</option>
                                    <option value="7">7</option>
                                    <option value="8">8</option>
                                    <option value="9">9</option>
                                    <option value="10">10</option>
                                    <option value="11">11</option>
                                    <option value="12">12</option>
                                </select>
                            </div>
                            <span class="field-error" id="sizeError"></span>
                        </div>

                        <div class="form-group full">
                            <label class="form-label">Description</label>
                            <textarea id="description" name="Pdescription" class="form-control" placeholder="Describe the product…"></textarea>
                            <span class="field-error" id="descriptionError"></span>
                        </div>

                    </div>

                    <!-- Pricing -->
                    <div class="section-gap">
                        <p class="form-section-title">Pricing & Inventory</p>
                        <div class="form-grid">

                            <div class="form-group">
                                <label class="form-label">Regular Price (₹)</label>
                                <input type="text" id="regularPrice" name="PregularPrice" class="form-control" placeholder="e.g. 1200">
                                <span class="field-error" id="regularPriceError"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Sale Price (₹)</label>
                                <input type="text" id="salePrice" name="PsalePrice" class="form-control" placeholder="e.g. 999">
                                <span class="field-error" id="salePriceError"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Units in Stock</label>
                                <input type="text" id="units" name="Punits" class="form-control" placeholder="e.g. 50">
                                <span class="field-error" id="unitsError"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Primary Color</label>
                                <input type="text" id="primaryColor" name="PprimaryColor" class="form-control" placeholder="e.g. White">
                                <span class="field-error" id="primaryColorError"></span>
                            </div>

                        </div>
                    </div>

                    <!-- Images -->
                    <div class="section-gap">
                        <p class="form-section-title">Product Images <span style="color:var(--dim);font-weight:400;letter-spacing:0;text-transform:none;font-size:.75rem;">(3–5 images required)</span></p>

                        <div class="upload-zone" id="uploadZone">
                            <input type="file" name="Pimages" id="imageInput" multiple accept="image/*">
                            <div class="upload-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                            <div class="upload-text">Click or drag images here</div>
                            <div class="upload-hint">Accepted: JPG, PNG, WEBP — 3 to 5 images</div>
                        </div>

                        <!-- Cropper -->
                        <div class="cropper-area" id="cropperArea">
                            <p style="font-size:.72rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:.75rem;">
                                <i class="bi bi-crop"></i> Crop Image <span id="cropCounter"></span>
                            </p>
                            <img id="currentImagePreview" alt="Preview">
                            <div class="crop-actions">
                                <button id="cropButton" class="btn-crop" type="button">
                                    <i class="bi bi-scissors"></i> Crop & Continue
                                </button>
                            </div>
                        </div>

                        <!-- Cropped thumbs -->
                        <div class="cropped-grid" id="croppedImagesContainer"></div>
                        <span class="field-error" id="imageError" style="margin-top:.35rem;display:block;"></span>
                    </div>

                    <!-- Footer -->
                    <div class="form-footer">
                        <a href="/admin/product" class="btn-cancel">Cancel</a>
                        <button type="submit" class="btn-submit">
                            <i class="bi bi-plus-lg"></i> Add Product
                        </button>
                    </div>

                </form>
            </div>

        </main>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script>
        // ── Sidebar ──
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        document.getElementById('hamburgerBtn').addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });
        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        });

        // ── Image cropper ──
        const imageInput      = document.getElementById('imageInput');
        const cropperArea     = document.getElementById('cropperArea');
        const imgPreview      = document.getElementById('currentImagePreview');
        const cropBtn         = document.getElementById('cropButton');
        const cropCounter     = document.getElementById('cropCounter');
        const croppedGrid     = document.getElementById('croppedImagesContainer');

        let cropper, fileQueue = [], currentIndex = 0, croppedImages = [];

        imageInput.addEventListener('change', () => {
            fileQueue = Array.from(imageInput.files);
            currentIndex = 0;
            croppedImages = [];
            croppedGrid.innerHTML = '';
            if (fileQueue.length) showImageForCropping();
        });

        function showImageForCropping() {
            const file = fileQueue[currentIndex];
            const reader = new FileReader();
            reader.onload = () => {
                imgPreview.src = reader.result;
                cropperArea.classList.add('visible');
                cropCounter.textContent = `(${currentIndex + 1} of ${fileQueue.length})`;
                if (cropper) cropper.destroy();
                cropper = new Cropper(imgPreview, { aspectRatio: 0, viewMode: 1 });
            };
            reader.readAsDataURL(file);
        }

        cropBtn.addEventListener('click', (e) => {
            e.preventDefault();
            const cropped = cropper.getCroppedCanvas().toDataURL('image/jpeg');
            croppedImages.push(cropped);
            cropper.destroy();
            currentIndex++;
            if (currentIndex < fileQueue.length) {
                showImageForCropping();
            } else {
                cropperArea.classList.remove('visible');
                displayCroppedImages();
            }
        });

        function displayCroppedImages() {
            croppedGrid.innerHTML = croppedImages.map((img, i) => `
                <div class="cropped-thumb" id="thumb-${i}">
                    <img src="${img}" alt="Cropped ${i+1}">
                    <button class="remove-thumb" type="button" onclick="removeCroppedImage(${i})">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            `).join('');
        }

        function removeCroppedImage(index) {
            croppedImages.splice(index, 1);
            fileQueue.splice(index, 1);
            const dt = new DataTransfer();
            fileQueue.forEach(f => dt.items.add(f));
            imageInput.files = dt.files;
            displayCroppedImages();
        }

        // ── Validation ──
        function validateForm() {
            let isValid = true;
            document.querySelectorAll('.field-error').forEach(el => el.textContent = '');
            document.querySelectorAll('.form-control, .form-select').forEach(el => el.classList.remove('is-invalid'));

            const check = (id, errId, condition, msg) => {
                if (condition) {
                    document.getElementById(errId).textContent = msg;
                    document.getElementById(id)?.classList.add('is-invalid');
                    isValid = false;
                }
            };

            const productName = document.getElementById('productName').value.trim();
            check('productName', 'productNameError', !productName, 'Product name is required.');

            const category = document.getElementById('category').value;
            check('category', 'categoryError', !category, 'Please select a category.');

            const description = document.getElementById('description').value.trim();
            check('description', 'descriptionError', !description, 'Description is required.');

            const regularPrice = document.getElementById('regularPrice').value.trim();
            check('regularPrice', 'regularPriceError', !regularPrice, 'Regular price is required.');
            check('regularPrice', 'regularPriceError', regularPrice && isNaN(regularPrice), 'Must be a valid number.');
            check('regularPrice', 'regularPriceError', regularPrice && Number(regularPrice) <= 0, 'Must be greater than zero.');

            const salePrice = document.getElementById('salePrice').value.trim();
            check('salePrice', 'salePriceError', !salePrice, 'Sale price is required.');
            check('salePrice', 'salePriceError', salePrice && isNaN(salePrice), 'Must be a valid number.');
            check('salePrice', 'salePriceError', salePrice && Number(salePrice) < 0, 'Cannot be negative.');
            check('salePrice', 'salePriceError', salePrice && regularPrice && Number(salePrice) > Number(regularPrice), 'Sale price cannot exceed regular price.');

            const units = document.getElementById('units').value.trim();
            check('units', 'unitsError', !units, 'Units is required.');

            const primaryColor = document.getElementById('primaryColor').value.trim();
            check('primaryColor', 'primaryColorError', !primaryColor, 'Primary color is required.');

            const size = document.getElementById('size').value;
            check('size', 'sizeError', !size, 'Please select a size.');

            const fileCount = imageInput.files.length;
            if (fileCount < 3 || fileCount > 5) {
                document.getElementById('imageError').textContent = 'Please upload between 3 and 5 images.';
                isValid = false;
            }

            return isValid;
        }
    </script>
</body>
</html>