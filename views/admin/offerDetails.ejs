<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fashion Feet — Category Offer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:       #0f0f0f;
            --surface:  #1a1a1a;
            --surface2: #222222;
            --border:   #2a2a2a;
            --border2:  #333;
            --cream:    #f0e6d3;
            --muted:    #999;
            --dim:      #555;
            --gold1:    #c9a96e;
            --gold2:    #a8813d;
            --error:    #e05f5f;
            --success:  #4caf7d;
            --sidebar-w: 220px;
        }

        html, body { height: 100%; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg); color: var(--cream);
            display: flex; flex-direction: column; min-height: 100vh;
        }

        /* ── Navbar ── */
        .navbar {
            position: sticky; top: 0; z-index: 100;
            background: var(--surface); border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            padding: .85rem 1.5rem; gap: 1rem;
        }
        .navbar-brand {
            font-family: 'Playfair Display', serif; font-size: 1.45rem;
            color: var(--cream); letter-spacing: 1px; text-decoration: none;
        }
        .navbar-right { display: flex; align-items: center; gap: 1rem; }
        .navbar-badge {
            font-size: .65rem; letter-spacing: 2px; text-transform: uppercase;
            color: var(--muted); border: 1px solid var(--border2);
            padding: .25rem .65rem; border-radius: 20px;
        }
        .logout-btn {
            font-size: .75rem; font-weight: 500; letter-spacing: 1.5px;
            text-transform: uppercase; color: var(--muted); text-decoration: none;
            padding: .4rem .9rem; border: 1px solid var(--border2); border-radius: 6px;
            transition: color .2s, border-color .2s;
            display: flex; align-items: center; gap: .4rem;
        }
        .logout-btn:hover { color: var(--gold1); border-color: var(--gold1); }
        .hamburger {
            display: none; background: none; border: 1px solid var(--border2);
            border-radius: 6px; color: var(--muted); font-size: 1.2rem;
            padding: .3rem .55rem; cursor: pointer;
        }

        /* ── Layout ── */
        .layout { display: flex; flex: 1; overflow: hidden; }

        /* ── Sidebar ── */
        .sidebar {
            width: var(--sidebar-w); background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            padding: 1.5rem 1rem; gap: .35rem;
            flex-shrink: 0; transition: transform .3s ease;
        }
        .sidebar-label {
            font-size: .6rem; letter-spacing: 2.5px; text-transform: uppercase;
            color: var(--dim); padding: .5rem .65rem .2rem; margin-top: .5rem;
        }
        .nav-link {
            display: flex; align-items: center; gap: .65rem;
            padding: .65rem .85rem; border-radius: 8px;
            color: var(--muted); text-decoration: none;
            font-size: .86rem; font-weight: 500;
            transition: background .2s, color .2s;
        }
        .nav-link i { font-size: 1rem; width: 1.1rem; text-align: center; }
        .nav-link:hover { background: var(--surface2); color: var(--cream); }
        .nav-link.active {
            background: linear-gradient(135deg, rgba(201,169,110,.18), rgba(168,129,61,.1));
            color: var(--gold1); border: 1px solid rgba(201,169,110,.2);
        }
        .sidebar-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.6); z-index: 90;
        }

        /* ── Main ── */
        .main {
            flex: 1; overflow-y: auto;
            padding: 2rem 1.75rem;
            display: flex; flex-direction: column; gap: 1.5rem;
        }

        /* ── Page header ── */
        .page-header {
            display: flex; align-items: center;
            justify-content: space-between; flex-wrap: wrap; gap: 1rem;
        }
        .page-title-wrap { display: flex; align-items: center; gap: .85rem; }
        .back-btn {
            display: inline-flex; align-items: center; gap: .4rem;
            font-size: .78rem; font-weight: 500; letter-spacing: 1px;
            text-transform: uppercase; color: var(--muted);
            text-decoration: none; padding: .4rem .9rem;
            border: 2px solid var(--border2); border-radius: 6px;
            transition: color .2s, border-color .2s; cursor: pointer; background: none;
        }
        .back-btn:hover { color: var(--gold1); border-color: var(--gold1); }
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem; font-weight: 700; color: var(--cream);
        }
        .cat-badge {
            font-size: .65rem; letter-spacing: 2px; text-transform: uppercase;
            background: rgba(201,169,110,.1); border: 1px solid rgba(201,169,110,.25);
            color: var(--gold1); padding: .25rem .75rem; border-radius: 20px;
        }

        .tab-bar { display: flex; gap: .5rem; }
        .tab-btn {
            padding: .45rem 1.1rem; border-radius: 8px;
            border: 1px solid var(--border2); background: transparent;
            color: var(--muted); font-family: 'DM Sans', sans-serif;
            font-size: .78rem; font-weight: 500; letter-spacing: 1px;
            text-transform: uppercase; cursor: pointer; transition: all .2s;
        }
        .tab-btn:hover { border-color: var(--gold1); color: var(--gold1); }
        .tab-btn.active {
            background: linear-gradient(135deg, var(--gold1), var(--gold2));
            border-color: transparent; color: #0f0f0f; font-weight: 700;
        }

        /* ── Sections ── */
        .section { animation: fadeUp .35s ease both; }
        .section.hidden { display: none; }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Offer card ── */
        .offer-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 12px; overflow: hidden;
        }
        .offer-card-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border);
            flex-wrap: wrap; gap: .75rem;
        }
        .offer-card-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem; color: var(--cream);
        }
        .status-pill {
            font-size: .68rem; font-weight: 700; letter-spacing: 1px;
            text-transform: uppercase; padding: .25rem .75rem; border-radius: 20px;
        }
        .status-active   { color: var(--success); background: rgba(76,175,125,.12); border: 1px solid rgba(76,175,125,.25); }
        .status-inactive { color: var(--dim);     background: rgba(85,85,85,.15);   border: 1px solid rgba(85,85,85,.3); }

        .offer-body { padding: 1.5rem; }
        .offer-grid {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 1rem; margin-bottom: 1.25rem;
        }
        .offer-stat {
            background: var(--surface2); border: 1px solid var(--border);
            border-radius: 10px; padding: 1rem 1.15rem;
        }
        .offer-stat-label {
            font-size: .65rem; letter-spacing: 1.8px; text-transform: uppercase;
            color: var(--dim); margin-bottom: .4rem;
        }
        .offer-stat-value {
            font-family: 'Playfair Display', serif;
            font-size: 1.25rem; color: var(--cream);
        }
        .offer-stat-value.gold { color: var(--gold1); }
        .offer-desc-label {
            font-size: .65rem; letter-spacing: 1.8px; text-transform: uppercase;
            color: var(--dim); margin-bottom: .5rem;
        }
        .offer-desc {
            font-size: .88rem; color: var(--muted); line-height: 1.6;
            background: var(--surface2); border: 1px solid var(--border);
            border-radius: 8px; padding: .85rem 1rem;
        }
        .offer-actions {
            display: flex; gap: .75rem; padding: 1.25rem 1.5rem;
            border-top: 1px solid var(--border); flex-wrap: wrap;
        }
        .btn-edit {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .55rem 1.1rem; border-radius: 8px;
            background: linear-gradient(135deg, var(--gold1), var(--gold2));
            border: none; color: #0f0f0f; font-family: 'DM Sans', sans-serif;
            font-weight: 700; font-size: .78rem; letter-spacing: 1px;
            text-transform: uppercase; cursor: pointer; transition: opacity .2s;
        }
        .btn-edit:hover { opacity: .85; }
        .btn-remove {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .55rem 1.1rem; border-radius: 8px;
            background: transparent; border: 1px solid rgba(224,95,95,.4);
            color: var(--error); font-family: 'DM Sans', sans-serif;
            font-weight: 600; font-size: .78rem; letter-spacing: 1px;
            text-transform: uppercase; cursor: pointer;
            transition: background .2s, border-color .2s;
        }
        .btn-remove:hover { background: rgba(224,95,95,.1); border-color: var(--error); }

        /* ── No offer ── */
        .no-offer {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 12px; padding: 4rem 2rem;
            display: flex; flex-direction: column; align-items: center;
            gap: 1rem; text-align: center;
        }
        .no-offer-icon { font-size: 2.5rem; color: var(--dim); }
        .no-offer-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--muted); }
        .no-offer-sub   { font-size: .83rem; color: var(--dim); }
        .btn-add-offer {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .65rem 1.4rem; border-radius: 8px;
            background: linear-gradient(135deg, var(--gold1), var(--gold2));
            border: none; color: #0f0f0f; font-family: 'DM Sans', sans-serif;
            font-weight: 700; font-size: .8rem; letter-spacing: 1px;
            text-transform: uppercase; cursor: pointer;
            transition: opacity .2s, transform .15s; margin-top: .5rem;
        }
        .btn-add-offer:hover { opacity: .87; transform: translateY(-1px); }

        /* ── History table ── */
        .history-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 12px; overflow: hidden;
        }
        .history-card .table-wrap { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; font-size: .83rem; white-space: nowrap; }
        thead tr { background: var(--surface2); border-bottom: 1px solid var(--border); }
        th {
            padding: .85rem 1rem; text-align: left;
            font-size: .65rem; font-weight: 600;
            letter-spacing: 1.8px; text-transform: uppercase; color: var(--muted);
        }
        tbody tr { border-bottom: 1px solid var(--border); transition: background .15s; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: var(--surface2); }
        td { padding: .85rem 1rem; color: var(--cream); vertical-align: middle; }
        .discount-chip {
            font-size: .72rem; font-weight: 700; color: var(--gold1);
            background: rgba(201,169,110,.1); border: 1px solid rgba(201,169,110,.2);
            padding: .2rem .6rem; border-radius: 20px; display: inline-block;
        }
        .empty-history {
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; gap: .75rem; padding: 4rem 2rem; text-align: center;
        }
        .empty-icon   { font-size: 2.5rem; color: var(--dim); }
        .empty-title  { font-family: 'Playfair Display', serif; font-size: 1.05rem; color: var(--muted); }

        /* ══════════════════════════════════════
           DRAWER — Slide-in offer form
        ══════════════════════════════════════ */
        .drawer-backdrop {
            position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,0);
            pointer-events: none;
            transition: background .3s ease;
        }
        .drawer-backdrop.open {
            background: rgba(0,0,0,.65);
            pointer-events: all;
        }

        .drawer {
            position: fixed; top: 0; right: 0; bottom: 0; z-index: 201;
            width: 440px; max-width: 100vw;
            background: #161616;
            border-left: 1px solid var(--border);
            display: flex; flex-direction: column;
            transform: translateX(100%);
            transition: transform .35s cubic-bezier(.4,0,.2,1);
            overflow: hidden;
        }
        .drawer.open { transform: translateX(0); }

        /* Drawer header */
        .drawer-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.4rem 1.5rem;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }
        .drawer-title-block {}
        .drawer-eyebrow {
            font-size: .6rem; letter-spacing: 2.5px; text-transform: uppercase;
            color: var(--dim); margin-bottom: .3rem;
        }
        .drawer-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem; color: var(--cream);
        }
        .drawer-close {
            width: 32px; height: 32px; border-radius: 8px;
            background: transparent; border: 1px solid var(--border2);
            color: var(--muted); font-size: 1rem; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: color .2s, border-color .2s, background .2s;
        }
        .drawer-close:hover {
            color: var(--cream); border-color: #555; background: var(--surface2);
        }

        /* Drawer body */
        .drawer-body {
            flex: 1; overflow-y: auto;
            padding: 1.5rem;
            display: flex; flex-direction: column; gap: 1.15rem;
        }

        /* Field group */
        .field-group { display: flex; flex-direction: column; gap: .45rem; }
        .field-label {
            font-size: .65rem; letter-spacing: 2px; text-transform: uppercase;
            color: var(--dim); display: flex; align-items: center; gap: .35rem;
        }
        .field-label .req { color: var(--gold1); font-size: .7rem; }

        .field-input, .field-textarea {
            width: 100%; background: var(--surface2);
            border: 1px solid var(--border2); border-radius: 8px;
            color: var(--cream); font-family: 'DM Sans', sans-serif;
            font-size: .88rem; padding: .75rem 1rem;
            transition: border-color .2s, box-shadow .2s;
            outline: none; appearance: none;
        }
        .field-input:focus, .field-textarea:focus {
            border-color: var(--gold1);
            box-shadow: 0 0 0 3px rgba(201,169,110,.12);
        }
        .field-input::placeholder, .field-textarea::placeholder { color: var(--dim); }
        .field-textarea { resize: vertical; min-height: 90px; }

        /* Date row */
        .date-row { display: grid; grid-template-columns: 1fr 1fr; gap: .85rem; }

        /* Discount field with % badge */
        .discount-wrap { position: relative; }
        .discount-wrap .field-input { padding-right: 2.75rem; }
        .discount-suffix {
            position: absolute; right: .9rem; top: 50%; transform: translateY(-50%);
            font-size: .8rem; font-weight: 700; color: var(--gold1);
            pointer-events: none;
        }

        /* Discount range slider */
        .discount-range-row {
            display: flex; align-items: center; gap: .75rem; margin-top: .25rem;
        }
        .discount-range-row input[type="range"] {
            flex: 1; -webkit-appearance: none; appearance: none;
            height: 4px; background: var(--border2); border-radius: 4px; outline: none; cursor: pointer;
        }
        .discount-range-row input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none; width: 16px; height: 16px; border-radius: 50%;
            background: var(--gold1); cursor: pointer;
            box-shadow: 0 0 0 3px rgba(201,169,110,.2);
        }
        .discount-range-row input[type="range"]::-moz-range-thumb {
            width: 16px; height: 16px; border-radius: 50%;
            background: var(--gold1); cursor: pointer; border: none;
        }
        .range-label {
            font-size: .75rem; color: var(--muted); min-width: 2.5rem; text-align: right;
        }

        /* Divider */
        .drawer-divider {
            border: none; border-top: 1px solid var(--border);
            margin: .25rem 0;
        }

        /* Validation message */
        .validation-msg {
            display: none; align-items: center; gap: .4rem;
            background: rgba(224,95,95,.1); border: 1px solid rgba(224,95,95,.3);
            color: var(--error); border-radius: 8px;
            padding: .65rem .9rem; font-size: .8rem;
        }
        .validation-msg.visible { display: flex; }

        /* Drawer footer */
        .drawer-footer {
            padding: 1.15rem 1.5rem;
            border-top: 1px solid var(--border);
            display: flex; gap: .75rem; flex-shrink: 0;
            background: #161616;
        }
        .btn-save {
            flex: 1; display: inline-flex; align-items: center; justify-content: center;
            gap: .4rem; padding: .75rem 1.25rem; border-radius: 8px;
            background: linear-gradient(135deg, var(--gold1), var(--gold2));
            border: none; color: #0f0f0f; font-family: 'DM Sans', sans-serif;
            font-weight: 700; font-size: .82rem; letter-spacing: 1px;
            text-transform: uppercase; cursor: pointer; transition: opacity .2s;
        }
        .btn-save:hover { opacity: .87; }
        .btn-save:disabled { opacity: .45; cursor: not-allowed; }
        .btn-cancel-drawer {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .75rem 1.15rem; border-radius: 8px;
            background: transparent; border: 1px solid var(--border2);
            color: var(--muted); font-family: 'DM Sans', sans-serif;
            font-size: .82rem; font-weight: 600; letter-spacing: 1px;
            text-transform: uppercase; cursor: pointer; transition: color .2s, border-color .2s;
        }
        .btn-cancel-drawer:hover { color: var(--cream); border-color: #555; }

        /* Loading spinner inside button */
        .btn-save .spinner {
            display: none; width: 14px; height: 14px; border-radius: 50%;
            border: 2px solid rgba(0,0,0,.3); border-top-color: #0f0f0f;
            animation: spin .6s linear infinite;
        }
        .btn-save.loading .spinner { display: block; }
        .btn-save.loading .btn-label { display: none; }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Remove confirm dialog ── */
        .confirm-overlay {
            position: fixed; inset: 0; z-index: 300;
            background: rgba(0,0,0,.75);
            display: none; align-items: center; justify-content: center;
        }
        .confirm-overlay.open { display: flex; }
        .confirm-box {
            background: #1c1c1c; border: 1px solid var(--border2);
            border-radius: 14px; padding: 2rem; width: 360px; max-width: 92vw;
            text-align: center;
            animation: popIn .25s cubic-bezier(.34,1.56,.64,1);
        }
        @keyframes popIn {
            from { opacity: 0; transform: scale(.92); }
            to   { opacity: 1; transform: scale(1); }
        }
        .confirm-icon {
            width: 52px; height: 52px; border-radius: 50%;
            background: rgba(224,95,95,.1); border: 1px solid rgba(224,95,95,.25);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1rem; font-size: 1.35rem; color: var(--error);
        }
        .confirm-title {
            font-family: 'Playfair Display', serif; font-size: 1.1rem;
            color: var(--cream); margin-bottom: .4rem;
        }
        .confirm-sub { font-size: .83rem; color: var(--muted); margin-bottom: 1.5rem; line-height: 1.5; }
        .confirm-btns { display: flex; gap: .75rem; }
        .confirm-btns .btn-cancel-drawer { flex: 1; justify-content: center; }
        .btn-danger {
            flex: 1; display: inline-flex; align-items: center; justify-content: center;
            gap: .4rem; padding: .75rem 1rem; border-radius: 8px;
            background: var(--error); border: none; color: #fff;
            font-family: 'DM Sans', sans-serif; font-weight: 700;
            font-size: .82rem; letter-spacing: 1px; text-transform: uppercase;
            cursor: pointer; transition: opacity .2s;
        }
        .btn-danger:hover { opacity: .85; }

        /* ── Toast ── */
        .toast-wrap {
            position: fixed; top: 1.25rem; right: 1.25rem; z-index: 400;
            display: flex; flex-direction: column; gap: .5rem; pointer-events: none;
        }
        .toast {
            display: flex; align-items: center; gap: .6rem;
            padding: .7rem 1.1rem; border-radius: 10px;
            font-size: .82rem; font-weight: 500; min-width: 220px;
            animation: toastIn .3s ease;
            pointer-events: none;
        }
        .toast.success {
            background: #0f2a1d; border: 1px solid rgba(76,175,125,.35);
            color: var(--success);
        }
        .toast.error {
            background: #2a0f0f; border: 1px solid rgba(224,95,95,.35);
            color: var(--error);
        }
        @keyframes toastIn { from { opacity: 0; transform: translateX(16px); } to { opacity: 1; transform: translateX(0); } }

        /* ── Responsive ── */
        @media (max-width: 768px) {
            :root { --sidebar-w: 240px; }
            .hamburger { display: block; }
            .sidebar {
                position: fixed; top: 0; left: 0; bottom: 0;
                z-index: 95; transform: translateX(-100%); padding-top: 4.5rem;
            }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { padding: 1.25rem 1rem; }
            .navbar-badge { display: none; }
            .offer-grid { grid-template-columns: 1fr 1fr; }
            .drawer { width: 100vw; }
            .date-row { grid-template-columns: 1fr; }
        }
        @media (max-width: 480px) {
            .offer-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- ── NAVBAR ── -->
    <header class="navbar">
        <div style="display:flex;align-items:center;gap:.85rem;">
            <button class="hamburger" id="hamburgerBtn"><i class="bi bi-list"></i></button>
            <a class="navbar-brand" href="#">Fashion Feet</a>
        </div>
        <div class="navbar-right">
            <span class="navbar-badge">Admin Portal</span>
            <a href="/admin/logout" class="logout-btn">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>
    </header>

    <div class="layout">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- ── SIDEBAR ── -->
        <aside class="sidebar" id="sidebar">
            <span class="sidebar-label">Main</span>
            <a class="nav-link" href="/admin/dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
            <a class="nav-link" href="/admin/customer"><i class="bi bi-people"></i> Customers</a>
            <a class="nav-link" href="/admin/product"><i class="bi bi-box-seam"></i> Products</a>
            <a class="nav-link" href="/admin/orderManagement"><i class="bi bi-basket3"></i> Orders</a>
            <span class="sidebar-label">Management</span>
            <a class="nav-link" href="/admin/couponManagement"><i class="bi bi-ticket-perforated"></i> Coupons</a>
            <a class="nav-link" href="/admin/salesReport"><i class="bi bi-bar-chart-line"></i> Sales Report</a>
            <a class="nav-link active" href="/admin/category"><i class="bi bi-tag"></i> Categories</a>
        </aside>

        <!-- ── MAIN ── -->
        <main class="main">

            <!-- Header -->
            <div class="page-header">
                <div class="page-title-wrap">
                    <a href="/admin/category" class="back-btn">
                        <i class="bi bi-arrow-left"></i> 
                    </a>
                    <div>
                        <!-- <p style="font-size:.65rem;letter-spacing:2px;text-transform:uppercase;color:var(--dim);margin-bottom:.2rem;">Category</p> -->
                        <h1 class="page-title"><%= category.name %></h1>
                    </div>
                    <!-- <span class="cat-badge"><i class="bi bi-tag"></i> <%= category.name %></span> -->
                </div>
                <div class="tab-bar">
                    <button class="tab-btn active" id="tabOffer" onclick="showTab('offer')">
                        <i class="bi bi-percent"></i> Offer
                    </button>
                    <button class="tab-btn" id="tabHistory" onclick="showTab('history')">
                        <i class="bi bi-clock-history"></i> History
                    </button>
                </div>
            </div>

            <!-- ── OFFER SECTION ── -->
            <div class="section" id="offerdetail-section">
                <% if (category.offer != null) { %>
                <div class="offer-card">
                    <div class="offer-card-header">
                        <div>
                            <p style="font-size:.65rem;letter-spacing:2px;text-transform:uppercase;color:var(--dim);margin-bottom:.3rem;">Active Offer</p>
                            <h2 class="offer-card-title"><%= category.offer.name %></h2>
                        </div>
                        <% if (category.offer.status == true) { %>
                            <span class="status-pill status-active"><i class="bi bi-check-circle"></i> Active</span>
                        <% } else { %>
                            <span class="status-pill status-inactive"><i class="bi bi-pause-circle"></i> Inactive</span>
                        <% } %>
                    </div>

                    <div class="offer-body">
                        <div class="offer-grid">
                            <div class="offer-stat">
                                <div class="offer-stat-label">Discount</div>
                                <div class="offer-stat-value gold"><%= category.offer.discount %>%</div>
                            </div>
                            <div class="offer-stat">
                                <div class="offer-stat-label">Start Date</div>
                                <div class="offer-stat-value" style="font-size:1rem;">
                                    <%= new Date(category.offer.startDate).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %>
                                </div>
                            </div>
                            <div class="offer-stat">
                                <div class="offer-stat-label">End Date</div>
                                <div class="offer-stat-value" style="font-size:1rem;">
                                    <%= new Date(category.offer.endDate).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %>
                                </div>
                            </div>
                        </div>

                        <div class="offer-desc-label">Description</div>
                        <div class="offer-desc"><%= category.offer.description %></div>
                    </div>

                    <div class="offer-actions">
                        <button class="btn-edit" onclick="editOffer('<%= category._id %>')">
                            <i class="bi bi-pencil"></i> Edit Offer
                        </button>
                        <% if (category.offer.status == false) { %>
                        <button class="btn-remove" onclick="confirmRemove('<%= category._id %>')">
                            <i class="bi bi-trash"></i> Remove Offer
                        </button>
                        <% } %>
                    </div>
                </div>

                <% } else { %>
                <div class="no-offer">
                    <div class="no-offer-icon"><i class="bi bi-percent"></i></div>
                    <p class="no-offer-title">No offer for this category</p>
                    <p class="no-offer-sub">Add a discount offer to boost sales in this category.</p>
                    <button class="btn-add-offer" onclick="addOffer('<%= category._id %>')">
                        <i class="bi bi-plus-lg"></i> Add Offer
                    </button>
                </div>
                <% } %>
            </div>

            <!-- ── HISTORY SECTION ── -->
            <div class="section hidden" id="offerHistory-section">
                <% if (category.offerHistory && category.offerHistory.length > 0) { %>
                <div class="history-card">
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Offer Name</th>
                                    <th>Discount</th>
                                    <th>Duration</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% category.offerHistory.forEach((offer, i) => { %>
                                <tr>
                                    <td style="color:var(--dim);font-size:.8rem;"><%= i + 1 %></td>
                                    <td style="font-weight:600;"><%= offer.name %></td>
                                    <td><span class="discount-chip"><%= offer.discount %>% off</span></td>
                                    <td style="color:var(--muted); font-size:.8rem;">
                                        <%= new Date(offer.startDate).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %>
                                        <span style="color:var(--dim);"> → </span>
                                        <%= new Date(offer.endDate).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %>
                                    </td>
                                    <td style="color:var(--muted); max-width:220px; white-space:normal; font-size:.8rem;"><%= offer.description %></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <% } else { %>
                <div class="history-card">
                    <div class="empty-history">
                        <div class="empty-icon"><i class="bi bi-clock-history"></i></div>
                        <p class="empty-title">No offer history yet</p>
                    </div>
                </div>
                <% } %>
            </div>

        </main>
    </div>

    <!-- ══════════════════════════════════════
         OFFER DRAWER
    ══════════════════════════════════════ -->
    <div class="drawer-backdrop" id="drawerBackdrop" onclick="closeDrawer()"></div>

    <div class="drawer" id="offerDrawer" role="dialog" aria-modal="true" aria-labelledby="drawerTitleText">
        <div class="drawer-header">
            <div class="drawer-title-block">
                <p class="drawer-eyebrow" id="drawerEyebrow">Category Offer</p>
                <h2 class="drawer-title" id="drawerTitleText">Add Offer</h2>
            </div>
            <button class="drawer-close" onclick="closeDrawer()" aria-label="Close drawer">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="drawer-body">
            <!-- Offer Name -->
            <div class="field-group">
                <label class="field-label" for="offerName">
                    Offer Name <span class="req">*</span>
                </label>
                <input
                    id="offerName"
                    class="field-input"
                    type="text"
                    placeholder="e.g. Summer Sale, Clearance Special"
                    autocomplete="off"
                    maxlength="80"
                />
            </div>

            <hr class="drawer-divider">

            <!-- Discount -->
            <div class="field-group">
                <label class="field-label" for="offerDiscount">
                    Discount <span class="req">*</span>
                </label>
                <div class="discount-wrap">
                    <input
                        id="offerDiscount"
                        class="field-input"
                        type="number"
                        min="1" max="90"
                        placeholder="10"
                        oninput="syncSlider(this.value)"
                    />
                    <span class="discount-suffix">%</span>
                </div>
                <div class="discount-range-row">
                    <input
                        type="range" id="discountSlider"
                        min="1" max="90" value="10" step="1"
                        oninput="syncInput(this.value)"
                    />
                    <span class="range-label" id="sliderLabel">10%</span>
                </div>
            </div>

            <hr class="drawer-divider">

            <!-- Dates -->
            <div class="date-row">
                <div class="field-group">
                    <label class="field-label" for="offerStartDate">
                        <i class="bi bi-calendar3" style="font-size:.75rem;"></i>
                        Start Date <span class="req">*</span>
                    </label>
                    <input id="offerStartDate" class="field-input" type="date" />
                </div>
                <div class="field-group">
                    <label class="field-label" for="offerEndDate">
                        <i class="bi bi-calendar3" style="font-size:.75rem;"></i>
                        End Date <span class="req">*</span>
                    </label>
                    <input id="offerEndDate" class="field-input" type="date" />
                </div>
            </div>

            <hr class="drawer-divider">

            <!-- Description -->
            <div class="field-group">
                <label class="field-label" for="offerDescription">
                    Description <span class="req">*</span>
                </label>
                <textarea
                    id="offerDescription"
                    class="field-textarea"
                    placeholder="Briefly describe this offer and what it applies to…"
                    maxlength="300"
                    rows="4"
                ></textarea>
            </div>

            <!-- Validation message -->
            <div class="validation-msg" id="validationMsg">
                <i class="bi bi-exclamation-circle"></i>
                <span id="validationText">All fields are required.</span>
            </div>
        </div>

        <div class="drawer-footer">
            <button class="btn-cancel-drawer" onclick="closeDrawer()">
                Cancel
            </button>
            <button class="btn-save" id="saveBtn" onclick="submitOffer()">
                <span class="spinner"></span>
                <span class="btn-label"><i class="bi bi-check-lg"></i> Save Offer</span>
            </button>
        </div>
    </div>

    <!-- ══════════════════════════════════════
         REMOVE CONFIRM
    ══════════════════════════════════════ -->
    <div class="confirm-overlay" id="confirmOverlay">
        <div class="confirm-box">
            <div class="confirm-icon"><i class="bi bi-trash3"></i></div>
            <p class="confirm-title">Remove this offer?</p>
            <p class="confirm-sub">This offer will be permanently removed and moved to history. This action cannot be undone.</p>
            <div class="confirm-btns">
                <button class="btn-cancel-drawer" onclick="closeConfirm()">Cancel</button>
                <button class="btn-danger" id="confirmRemoveBtn" onclick="doRemove()">
                    <i class="bi bi-trash"></i> Remove
                </button>
            </div>
        </div>
    </div>

    <!-- ── Toast container ── -->
    <div class="toast-wrap" id="toastWrap"></div>

    <script>
        /* ── Sidebar ── */
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        document.getElementById('hamburgerBtn').addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });
        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        });

        /* ── Tab switching ── */
        function showTab(tab) {
            const isOffer = tab === 'offer';
            document.getElementById('offerdetail-section').classList.toggle('hidden', !isOffer);
            document.getElementById('offerHistory-section').classList.toggle('hidden', isOffer);
            document.getElementById('tabOffer').classList.toggle('active', isOffer);
            document.getElementById('tabHistory').classList.toggle('active', !isOffer);
        }

        /* ── Toast ── */
        function showToast(type, text) {
            const wrap = document.getElementById('toastWrap');
            const t = document.createElement('div');
            t.className = `toast ${type}`;
            t.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i> ${text}`;
            wrap.appendChild(t);
            setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity .4s'; }, 2200);
            setTimeout(() => t.remove(), 2600);
        }

        /* ── Discount slider sync ── */
        function syncSlider(val) {
            const v = Math.min(90, Math.max(1, parseInt(val) || 1));
            document.getElementById('discountSlider').value = v;
            document.getElementById('sliderLabel').textContent = v + '%';
        }
        function syncInput(val) {
            document.getElementById('offerDiscount').value = val;
            document.getElementById('sliderLabel').textContent = val + '%';
        }

        /* ── Drawer state ── */
        let drawerMode = 'add';
        let drawerCategoryId = '';

        function openDrawer(mode, categoryId, prefill = {}) {
            drawerMode = mode;
            drawerCategoryId = categoryId;

            document.getElementById('drawerEyebrow').textContent = 'Category Offer';
            document.getElementById('drawerTitleText').textContent = mode === 'add' ? 'Add Offer' : 'Edit Offer';
            document.querySelector('#saveBtn .btn-label').innerHTML =
                mode === 'add' ? '<i class="bi bi-plus-lg"></i> Add Offer' : '<i class="bi bi-check-lg"></i> Update Offer';

            document.getElementById('offerName').value        = prefill.name        || '';
            document.getElementById('offerDiscount').value    = prefill.discount    || '';
            document.getElementById('offerStartDate').value   = prefill.startDate   || '';
            document.getElementById('offerEndDate').value     = prefill.endDate     || '';
            document.getElementById('offerDescription').value = prefill.description || '';

            const discVal = parseInt(prefill.discount) || 10;
            document.getElementById('discountSlider').value   = discVal;
            document.getElementById('sliderLabel').textContent = discVal + '%';

            hideValidation();

            document.getElementById('drawerBackdrop').classList.add('open');
            document.getElementById('offerDrawer').classList.add('open');
            document.body.style.overflow = 'hidden';

            setTimeout(() => document.getElementById('offerName').focus(), 350);
        }

        function closeDrawer() {
            document.getElementById('drawerBackdrop').classList.remove('open');
            document.getElementById('offerDrawer').classList.remove('open');
            document.body.style.overflow = '';
        }

        /* ── Validation ── */
        function showValidation(msg) {
            const el = document.getElementById('validationMsg');
            document.getElementById('validationText').textContent = msg;
            el.classList.add('visible');
            el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        function hideValidation() {
            document.getElementById('validationMsg').classList.remove('visible');
        }

        function validateForm() {
            const name        = document.getElementById('offerName').value.trim();
            const discount    = document.getElementById('offerDiscount').value.trim();
            const startDate   = document.getElementById('offerStartDate').value;
            const endDate     = document.getElementById('offerEndDate').value;
            const description = document.getElementById('offerDescription').value.trim();

            if (!name || !discount || !startDate || !endDate || !description) {
                showValidation('All fields are required.');
                return null;
            }
            const d = parseInt(discount);
            if (isNaN(d) || d < 1 || d > 90) {
                showValidation('Discount must be between 1 and 90.');
                return null;
            }
            if (new Date(endDate) <= new Date(startDate)) {
                showValidation('End date must be after start date.');
                return null;
            }
            hideValidation();
            return { offerName: name, discount, startDate, endDate, description };
        }

        /* ── Submit ── */
        async function submitOffer() {
            const data = validateForm();
            if (!data) return;

            const saveBtn = document.getElementById('saveBtn');
            saveBtn.classList.add('loading');
            saveBtn.disabled = true;

            try {
                const isAdd = drawerMode === 'add';
                const res = await fetch(isAdd ? '/admin/addOffer' : '/admin/editOffer', {
                    method: isAdd ? 'POST' : 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ categoryId: drawerCategoryId, ...data }),
                });
                const json = await res.json();
                if (json.success) {
                    showToast('success', isAdd ? 'Offer added successfully.' : 'Offer updated successfully.');
                    setTimeout(() => window.location.reload(), 800);
                } else {
                    showToast('error', json.message || 'Something went wrong.');
                    saveBtn.classList.remove('loading');
                    saveBtn.disabled = false;
                }
            } catch {
                showToast('error', 'Something went wrong. Please try again.');
                saveBtn.classList.remove('loading');
                saveBtn.disabled = false;
            }
        }

        /* ── Public entry points ── */
        function addOffer(categoryId) {
            openDrawer('add', categoryId);
        }

        function editOffer(categoryId) {
            openDrawer('edit', categoryId, {
                name:        '<%= category.offer ? category.offer.name : "" %>',
                discount:    '<%= category.offer ? category.offer.discount : "" %>',
                startDate:   '<%= category.offer ? new Date(category.offer.startDate).toISOString().slice(0,10) : "" %>',
                endDate:     '<%= category.offer ? new Date(category.offer.endDate).toISOString().slice(0,10) : "" %>',
                description: '<%= category.offer ? category.offer.description : "" %>',
            });
        }

        /* ── Remove confirm ── */
        let _removeCatId = '';
        function confirmRemove(categoryId) {
            _removeCatId = categoryId;
            document.getElementById('confirmOverlay').classList.add('open');
        }
        function closeConfirm() {
            document.getElementById('confirmOverlay').classList.remove('open');
        }
        async function doRemove() {
            const btn = document.getElementById('confirmRemoveBtn');
            btn.disabled = true; btn.textContent = 'Removing…';
            try {
                const res = await fetch('/admin/deleteOffer', {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ categoryId: _removeCatId }),
                });
                const json = await res.json();
                if (json.success) {
                    showToast('success', 'Offer removed.');
                    setTimeout(() => window.location.reload(), 800);
                } else {
                    showToast('error', json.message || 'Something went wrong.');
                    closeConfirm();
                }
            } catch {
                showToast('error', 'Something went wrong. Please try again.');
                closeConfirm();
            }
        }

        /* ── Keyboard: Escape closes ── */
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeDrawer();
                closeConfirm();
            }
        });
    </script>
</body>
</html>
