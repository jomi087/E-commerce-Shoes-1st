<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fashion Feet — Sales Report</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --bg: #0f0f0f; --surface: #1a1a1a; --surface2: #2a2a2a;
            --border: #2a2a2a; --border2: #3a3a3a;
            --cream: #f0e6d3; --muted: #999; --dim: #666;
            --gold1: #c9a96e; --gold2: #a8813d;
            --error: #e05f5f; --success: #4caf7d; --info: #5ba8c9;
            --sidebar-w: 220px;
        }
        html { height: 100%; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--cream);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* NAVBAR */
        .navbar {
            position: sticky; top: 0; z-index: 100;
            background: var(--surface); border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            padding: .85rem 1.5rem; gap: 1rem; flex-shrink: 0;
        }
        .navbar-brand { font-family: 'Playfair Display', serif; font-size: 1.45rem; color: var(--cream); letter-spacing: 1px; white-space: nowrap; text-decoration: none; }
        .navbar-right { display: flex; align-items: center; gap: 1rem; }
        .navbar-badge { font-size: .65rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); border: 1px solid var(--border2); padding: .25rem .65rem; border-radius: 20px; }
        .logout-btn { font-size: .75rem; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); text-decoration: none; padding: .4rem .9rem; border: 1px solid var(--border2); border-radius: 6px; transition: color .2s, border-color .2s; display: flex; align-items: center; gap: .4rem; }
        .logout-btn:hover { color: var(--gold1); border-color: var(--gold1); }
        .hamburger { display: none; background: none; border: 1px solid var(--border2); border-radius: 6px; color: var(--muted); font-size: 1.2rem; padding: .3rem .55rem; cursor: pointer; }

        /* LAYOUT */
        .layout { display: flex; flex: 1; }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            padding: 1.5rem 1rem; gap: .35rem;
            flex-shrink: 0;
            position: sticky;
            top: 57px;
            height: calc(100vh - 57px);
            overflow-y: auto;
            transition: transform .3s ease;
        }
        .sidebar-label { font-size: .6rem; letter-spacing: 2.5px; text-transform: uppercase; color: var(--dim); padding: .5rem .65rem .2rem; margin-top: .5rem; }
        .nav-link { display: flex; align-items: center; gap: .65rem; padding: .65rem .85rem; border-radius: 8px; color: var(--muted); text-decoration: none; font-size: .86rem; font-weight: 500; transition: background .2s, color .2s; }
        .nav-link i { font-size: 1rem; width: 1.1rem; text-align: center; }
        .nav-link:hover { background: var(--surface2); color: var(--cream); }
        .nav-link.active { background: linear-gradient(135deg, rgba(201,169,110,.18), rgba(168,129,61,.1)); color: var(--gold1); border: 1px solid rgba(201,169,110,.2); }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 90; }

        /* MAIN */
        .main {
            flex: 1;
            padding: 2rem 1.75rem;
            display: flex; flex-direction: column; gap: 1.75rem;
            min-width: 0;
        }
        .page-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
        .page-title { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 700; color: var(--cream); }

        /* CARDS */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            animation: fadeUp .5s ease both;
        }
        .card-header {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            gap: 1rem; flex-wrap: wrap;
        }
        .card-title { font-family: 'Playfair Display', serif; font-size: 1.05rem; color: var(--cream); }
        .card-body { padding: 1.5rem; }

        @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

        /* TOP ROW: filter + summary */
        .top-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

        /* FILTER CARD */
        .form-label { font-size: .72rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); font-weight: 600; display: block; margin-bottom: .45rem; }
        .form-input {
            background: #111;
            border: 1px solid #444;
            border-radius: 8px;
            padding: .65rem .9rem;
            color: var(--cream);
            font-family: 'DM Sans', sans-serif;
            font-size: .85rem;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            width: 100%;
        }
        .form-input:focus { border-color: var(--gold1); box-shadow: 0 0 0 3px rgba(201,169,110,.12); }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
        .field-error { font-size: .72rem; color: var(--error); min-height: 1.1em; display: block; margin-top: .25rem; }

        /* QUICK FILTER PILLS */
        .quick-filters { display: flex; gap: .6rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
        .pill-btn {
            font-size: .72rem; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;
            padding: .4rem 1rem; border-radius: 20px;
            border: 1px solid var(--border2); background: transparent;
            color: var(--muted); cursor: pointer;
            transition: color .2s, border-color .2s, background .2s;
            font-family: 'DM Sans', sans-serif;
        }
        .pill-btn:hover { color: var(--gold1); border-color: var(--gold1); background: rgba(201,169,110,.08); }
        .pill-btn.active { color: #0f0f0f; background: linear-gradient(135deg, var(--gold1), var(--gold2)); border-color: transparent; }

        /* SUBMIT BTN */
        .submit-btn {
            display: inline-flex; align-items: center; gap: .5rem;
            padding: .65rem 1.5rem; width: 100%; justify-content: center;
            background: linear-gradient(135deg, var(--gold1), var(--gold2));
            border: none; border-radius: 8px;
            color: #0f0f0f; font-family: 'DM Sans', sans-serif;
            font-size: .82rem; font-weight: 700; letter-spacing: 1px;
            text-transform: uppercase; cursor: pointer;
            transition: opacity .2s, transform .15s;
            margin-top: .5rem;
        }
        .submit-btn:hover { opacity: .88; transform: translateY(-1px); }

        /* SUMMARY CARD */
        .summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .85rem; }
        .summary-item {
            background: var(--surface2);
            border: 1px solid var(--border2);
            border-radius: 10px;
            padding: .9rem 1rem;
        }
        .summary-label { font-size: .65rem; letter-spacing: 2px; text-transform: uppercase; color: var(--dim); margin-bottom: .35rem; }
        .summary-value { font-size: 1.25rem; font-weight: 700; color: var(--cream); }
        .summary-value.gold { color: var(--gold1); }
        .summary-value.green { color: var(--success); }
        .summary-value.red { color: var(--error); }
        .summary-value.blue { color: var(--info); }

        /* DOWNLOAD BTN */
        .download-group { display: flex; gap: .6rem; }
        .dl-btn {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .45rem 1rem; border-radius: 7px;
            border: 1px solid var(--border2); background: transparent;
            color: var(--muted); font-family: 'DM Sans', sans-serif;
            font-size: .75rem; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
            cursor: pointer; text-decoration: none;
            transition: color .2s, border-color .2s, background .2s;
        }
        .dl-btn-pdf:hover { color: var(--error); border-color: var(--error); background: rgba(224,95,95,.08); }
        .dl-btn-excel:hover { color: var(--success); border-color: var(--success); background: rgba(76,175,125,.08); }

        /* TABLE */
        .tbl-wrap { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; font-size: .82rem; }
        thead tr { background: var(--surface2); border-bottom: 1px solid var(--border2); }
        thead th { padding: .9rem 1rem; text-align: left; font-size: .65rem; letter-spacing: 2px; text-transform: uppercase; color: var(--dim); font-weight: 600; white-space: nowrap; }
        tbody tr { border-bottom: 1px solid var(--border); transition: background .15s; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: var(--surface2); }
        tbody td { padding: .85rem 1rem; color: var(--cream); font-size: .82rem; vertical-align: middle; }
        .td-id { font-family: monospace; font-size: .78rem; color: var(--muted); }
        .td-gold { color: var(--gold1); font-weight: 600; }
        .td-muted { color: var(--muted); }
        .td-green { color: var(--success); font-weight: 600; }
        .td-red { color: var(--error); }
        .empty-state { padding: 3.5rem 2rem; text-align: center; }
        .empty-state i { font-size: 2.5rem; color: var(--dim); display: block; margin-bottom: 1rem; }
        .empty-state p { color: var(--muted); font-size: .9rem; }

        /* RESPONSIVE */
        @media (max-width: 900px) { .top-row { grid-template-columns: 1fr; } }
        @media (max-width: 768px) {
            .hamburger { display: block; }
            .sidebar {
                position: fixed; top: 0; left: 0; bottom: 0;
                z-index: 95; height: 100vh;
                transform: translateX(-100%);
                padding-top: 4.5rem;
            }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { padding: 1.25rem 1rem; }
            .form-row { grid-template-columns: 1fr; }
            .summary-grid { grid-template-columns: 1fr 1fr; }
        }
        @media (max-width: 500px) {
            .navbar-badge { display: none; }
            .summary-grid { grid-template-columns: 1fr; }
            .download-group { flex-direction: column; }
        }
    </style>
</head>
<body>

    <header class="navbar">
        <div style="display:flex;align-items:center;gap:.85rem;">
            <button class="hamburger" id="hamburgerBtn" aria-label="Menu"><i class="bi bi-list"></i></button>
            <a class="navbar-brand" href="#">Fashion Feet</a>
        </div>
        <div class="navbar-right">
            <span class="navbar-badge">Admin Portal</span>
            <a href="/admin/logout" class="logout-btn"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </div>
    </header>

    <div class="layout">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="sidebar">
            <span class="sidebar-label">Main</span>
            <a class="nav-link" href="/admin/dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
            <a class="nav-link" href="/admin/customer"><i class="bi bi-people"></i> Customers</a>
            <a class="nav-link" href="/admin/product"><i class="bi bi-box-seam"></i> Products</a>
            <a class="nav-link" href="/admin/orderManagement"><i class="bi bi-basket3"></i> Orders</a>
            <span class="sidebar-label">Management</span>
            <a class="nav-link" href="/admin/couponManagement"><i class="bi bi-ticket-perforated"></i> Coupons</a>
            <a class="nav-link active" href="/admin/salesReport"><i class="bi bi-bar-chart-line"></i> Sales Report</a>
            <a class="nav-link" href="/admin/category"><i class="bi bi-tag"></i> Categories</a>
        </aside>

        <main class="main">
            <div class="page-header">
                <h1 class="page-title">Sales Report</h1>
                <div class="download-group">
                    <button class="dl-btn dl-btn-pdf" onclick="downloadSalesReport('pdf')">
                        <i class="bi bi-file-earmark-pdf"></i> PDF
                    </button>
                    <button class="dl-btn dl-btn-excel" onclick="downloadSalesReport('excel')">
                        <i class="bi bi-file-earmark-excel"></i> Excel
                    </button>
                </div>
            </div>

            <!-- TOP ROW: Filter + Summary -->
            <div class="top-row">
                <!-- Filter Card -->
                <div class="card" style="animation-delay:.05s;">
                    <div class="card-header">
                        <h2 class="card-title"><i class="bi bi-funnel" style="color:var(--gold1);margin-right:.5rem;"></i>Filter Sales</h2>
                    </div>
                    <div class="card-body">
                        <div class="quick-filters">
                            <button class="pill-btn" id="today" onclick="fetchSalesReport('today')">Today</button>
                            <button class="pill-btn" id="thisWeek" onclick="fetchSalesReport('thisWeek')">This Week</button>
                            <button class="pill-btn" id="thisMonth" onclick="fetchSalesReport('thisMonth')">This Month</button>
                        </div>
                        <form id="filterForm">
                            <div class="form-row">
                                <div>
                                    <label class="form-label" for="start-date">Start Date</label>
                                    <input type="date" id="start-date" class="form-input">
                                    <span class="field-error" id="start-date-error"></span>
                                </div>
                                <div>
                                    <label class="form-label" for="end-date">End Date</label>
                                    <input type="date" id="end-date" class="form-input">
                                    <span class="field-error" id="end-date-error"></span>
                                </div>
                            </div>
                            <button type="submit" class="submit-btn">
                                <i class="bi bi-search"></i> Apply Filters
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Summary Card -->
                <div class="card" style="animation-delay:.1s;">
                    <div class="card-header">
                        <h2 class="card-title"><i class="bi bi-bar-chart-line" style="color:var(--gold1);margin-right:.5rem;"></i>Sales Summary</h2>
                    </div>
                    <div class="card-body">
                        <div class="summary-grid">
                            <div class="summary-item">
                                <div class="summary-label">Total Sales</div>
                                <div class="summary-value green" id="totalSales">₹<%=salesSummary.totalSales%></div>
                            </div>
                            <div class="summary-item">
                                <div class="summary-label">Total Orders</div>
                                <div class="summary-value gold" id="totalOrders"><%=salesSummary.totalOrders%></div>
                            </div>
                            <div class="summary-item">
                                <div class="summary-label">Delivered</div>
                                <div class="summary-value blue" id="totalDelivered"><%=salesSummary.totalDelivered%></div>
                            </div>
                            <div class="summary-item">
                                <div class="summary-label">Returned</div>
                                <div class="summary-value" id="totalReturned"><%=salesSummary.totalReturned%></div>
                            </div>
                            <div class="summary-item" style="grid-column:1/-1;">
                                <div class="summary-label">Cancelled</div>
                                <div class="summary-value red" id="totalCanceled"><%=salesSummary.totalCanceled%></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Orders Table -->
            <div class="card" style="animation-delay:.15s;">
                <div class="card-header">
                    <h2 class="card-title">Order Details</h2>
                </div>
                <div class="tbl-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Actual Amount</th>
                                <th>Offer Discount</th>
                                <th>Coupon Discount</th>
                                <th>Total Discount</th>
                                <th>Order Amount</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody id="ordersTableBody">
                            <% if (orders.length) { %>
                                <% orders.forEach((order) => { %>
                                <tr>
                                    <td class="td-id"><%= order._id.toString().slice(-6) %></td>
                                    <td>₹<%= order.totalRegularPrice.toLocaleString('en-IN') %></td>
                                    <td class="td-muted">₹<%= order.discount %></td>
                                    <td class="td-muted"><%= order.coupon && order.coupon.id ? `₹${order.coupon.discount.toLocaleString('en-IN')}` : 'N/A' %></td>
                                    <td class="td-muted">₹<%= (order.discount + (order.coupon && order.coupon.id ? order.coupon.discount : 0)).toLocaleString('en-IN') %></td>
                                    <td class="<%= order.totalSalePrice === 0 ? 'td-red' : 'td-green' %>">
                                        <%= order.totalSalePrice === 0 ? 'Failed' : `₹${order.totalSalePrice.toLocaleString('en-IN')}` %>
                                    </td>
                                    <td class="td-muted"><%= new Date(order.orderDate).toLocaleDateString('en-GB') %></td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7">
                                        <div class="empty-state">
                                            <i class="bi bi-bar-chart-line"></i>
                                            <p>No orders found for the selected period.</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <script>
        // Sidebar toggle
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const hamburger = document.getElementById('hamburgerBtn');
        hamburger.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
        overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });

        // Filter form
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('filterForm').addEventListener('submit', async function (event) {
                event.preventDefault();
                const startDate = document.getElementById('start-date').value.trim();
                const endDate = document.getElementById('end-date').value.trim();
                let isValid = true;
                document.getElementById('start-date-error').textContent = '';
                document.getElementById('end-date-error').textContent = '';
                if (!startDate) { document.getElementById('start-date-error').textContent = 'Please select a start date.'; isValid = false; }
                if (!endDate) { document.getElementById('end-date-error').textContent = 'Please select an end date.'; isValid = false; }
                if (startDate && endDate && new Date(startDate) > new Date(endDate)) {
                    document.getElementById('end-date-error').textContent = 'End date must be after the start date.'; isValid = false;
                }
                if (isValid) { fetchSalesReport(null, startDate, endDate); }
            });
        });

        async function fetchSalesReport(filter = null, startDate = null, endDate = null) {
            document.querySelectorAll('.pill-btn').forEach(el => el.classList.remove('active'));
            let url = '/admin/generateSalesReport';
            if (filter) {
                document.getElementById(filter).classList.add('active');
                url += `?filter=${filter}`;
            } else if (startDate && endDate) {
                url += `?startDate=${startDate}&endDate=${endDate}`;
            }
            try {
                const response = await fetch(url);
                if (response.ok) {
                    const result = await response.json();
                    updateSalesSummary(result.salesSummary);
                    updateOrdersTable(result.orders);
                } else {
                    Swal.fire({ icon: 'error', title: 'Failed!', text: 'Failed to fetch sales report. Try again later.', confirmButtonText: 'OK' });
                }
            } catch (error) {
                console.log(error);
                Swal.fire({ icon: 'error', title: 'Error', text: 'Technical issue. Please try again later.', confirmButtonText: 'OK' });
            }
        }

        function updateSalesSummary(s) {
            document.getElementById('totalSales').textContent = `₹${s.totalSales}`;
            document.getElementById('totalOrders').textContent = `${s.totalOrders}`;
            document.getElementById('totalDelivered').textContent = `${s.totalDelivered}`;
            document.getElementById('totalCanceled').textContent = `${s.totalCanceled}`;
            if (document.getElementById('totalReturned')) document.getElementById('totalReturned').textContent = `${s.totalReturned}`;
        }

        function updateOrdersTable(orders) {
            const tbody = document.getElementById('ordersTableBody');
            if (orders.length > 0) {
                tbody.innerHTML = orders.map(order => `
                    <tr>
                        <td class="td-id">${order._id.toString().slice(-6)}</td>
                        <td>₹${order.totalRegularPrice.toLocaleString('en-IN')}</td>
                        <td class="td-muted">₹${order.discount.toLocaleString('en-IN')}</td>
                        <td class="td-muted">${order.coupon && order.coupon.id ? `₹${order.coupon.discount.toLocaleString('en-IN')}` : 'N/A'}</td>
                        <td class="td-muted">₹${(order.discount + (order.coupon && order.coupon.id ? order.coupon.discount : 0)).toLocaleString('en-IN')}</td>
                        <td class="${order.totalSalePrice === 0 ? 'td-red' : 'td-green'}">${order.totalSalePrice === 0 ? 'Failed' : `₹${order.totalSalePrice.toLocaleString('en-IN')}`}</td>
                        <td class="td-muted">${new Date(order.orderDate).toLocaleDateString('en-GB')}</td>
                    </tr>
                `).join('');
            } else {
                tbody.innerHTML = `<tr><td colspan="7"><div class="empty-state"><i class="bi bi-bar-chart-line"></i><p>No orders found for the selected period.</p></div></td></tr>`;
            }
        }

        function downloadSalesReport(format) {
            const startDate = document.getElementById('start-date').value.trim();
            const endDate = document.getElementById('end-date').value.trim();
            const activeFilter = document.querySelector('.pill-btn.active')?.id || null;
            let url = '/admin/downloadSalesReport?format=' + format;
            if (activeFilter) {
                url += `&filter=${activeFilter}`;
            } else if (startDate && endDate) {
                url += `&startDate=${startDate}&endDate=${endDate}`;
            } else {
                return Swal.fire({ title: 'Alert!', text: 'Please select a date range or quick filter first.', confirmButtonText: 'OK' });
            }
            window.location.href = url;
        }
    </script>
</body>
</html>
