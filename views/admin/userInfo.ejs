<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customers — Admin</title>

    <!-- SAME FONT + ICONS AS DASHBOARD -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0f0f0f;
            --surface: #1a1a1a;
            --surface2: #222222;
            --border: #2a2a2a;
            --border2: #333;
            --cream: #f0e6d3;
            --muted: #999;
            --dim: #555;
            --gold1: #c9a96e;
            --gold2: #a8813d;
            --error: #e05f5f;
            --success: #4caf7d;
            --sidebar-w: 220px;
        }

        html,
        body {
            height: 100%;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--cream);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ══════════════════════════════
           NAVBAR
        ══════════════════════════════ */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .85rem 1.5rem;
            gap: 1rem;
        }

        .navbar-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            color: var(--cream);
            letter-spacing: 1px;
            white-space: nowrap;
            text-decoration: none;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .navbar-badge {
            font-size: .65rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--muted);
            border: 1px solid var(--border2);
            padding: .25rem .65rem;
            border-radius: 20px;
        }

        .logout-btn {
            font-size: .75rem;
            font-weight: 500;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--muted);
            text-decoration: none;
            padding: .4rem .9rem;
            border: 1px solid var(--border2);
            border-radius: 6px;
            transition: color .2s, border-color .2s;
            display: flex;
            align-items: center;
            gap: .4rem;
        }

        .logout-btn:hover {
            color: var(--gold1);
            border-color: var(--gold1);
        }

        /* hamburger */
        .hamburger {
            display: none;
            background: none;
            border: 1px solid var(--border2);
            border-radius: 6px;
            color: var(--muted);
            font-size: 1.2rem;
            padding: .3rem .55rem;
            cursor: pointer;
        }

        /* ══════════════════════════════
           LAYOUT
        ══════════════════════════════ */
        .layout {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* ══════════════════════════════
           SIDEBAR
        ══════════════════════════════ */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 1.5rem 1rem;
            gap: .35rem;
            flex-shrink: 0;
            transition: transform .3s ease;
        }

        .sidebar-label {
            font-size: .6rem;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--dim);
            padding: .5rem .65rem .2rem;
            margin-top: .5rem;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: .65rem;
            padding: .65rem .85rem;
            border-radius: 8px;
            color: var(--muted);
            text-decoration: none;
            font-size: .86rem;
            font-weight: 500;
            transition: background .2s, color .2s;
        }

        .nav-link i {
            font-size: 1rem;
            width: 1.1rem;
            text-align: center;
        }

        .nav-link:hover {
            background: var(--surface2);
            color: var(--cream);
        }

        .nav-link.active {
            background: linear-gradient(135deg, rgba(201, 169, 110, .18), rgba(168, 129, 61, .1));
            color: var(--gold1);
            border: 1px solid rgba(201, 169, 110, .2);
        }

        /* overlay for mobile sidebar */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .6);
            z-index: 90;
        }

        /* ══════════════════════════════
           MAIN CONTENT
        ══════════════════════════════ */
        .main {
            flex: 1;
            overflow-y: auto;
            padding: 2rem 1.75rem;
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        /* page title */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: .75rem;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--cream);
        }

        .page-date {
            font-size: .78rem;
            color: var(--muted);
            letter-spacing: .5px;
        }

        /* ===== TABLE FIX ===== */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
            table-layout: fixed;
            /* prevents UI shift */
        }

        th,
        td {
            padding: .75rem;
            font-size: .85rem;
        }

        /* ===== ACTION BUTTON FIX ===== */
        .action-btn {
            display: inline-block;
            width: 90px;
            /* SAME WIDTH */
            text-align: center;
            padding: .35rem 0;
            border-radius: 6px;
            text-decoration: none;
            font-size: .8rem;
            transition: all .2s ease;
        }

        .action-btn.block {
            color: var(--error);
            border: 1px solid var(--error);
        }

        .action-btn.unblock {
            color: var(--success);
            border: 1px solid var(--success);
        }

        .action-btn:hover {
            transform: scale(1.05);
        }

        /* ===== MOBILE RESPONSIVE TABLE ===== */
        @media (max-width: 600px) {
            table thead {
                display: none;
            }

            table tr {
                display: block;
                margin-bottom: 1rem;
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: .5rem;
            }

            table td {
                display: flex;
                justify-content: space-between;
                padding: .5rem;
                font-size: .8rem;
            }

            table td::before {
                content: attr(data-label);
                color: var(--muted);
                font-size: .7rem;
            }
        }

        /* ══════════════════════════════
           RESPONSIVE
        ══════════════════════════════ */
        @media (max-width: 1100px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 900px) {
            .bottom-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            :root {
                --sidebar-w: 240px;
            }

            .hamburger {
                display: block;
            }

            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                bottom: 0;
                z-index: 95;
                transform: translateX(-100%);
                padding-top: 4.5rem;
            }

            .sidebar.open {
                transform: translateX(0);
            }

            .sidebar-overlay.open {
                display: block;
            }

            .main {
                padding: 1.25rem 1rem;
            }
        }

        @media (max-width: 500px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .navbar-badge {
                display: none;
            }
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <header class="navbar">
        <div style="display:flex;align-items:center;gap:.85rem;">
            <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
                <i class="bi bi-list"></i>
            </button>
            <a class="navbar-brand" href="#">Fashion Feet</a>
        </div>
        <div class="navbar-right">
            <span class="navbar-badge">Admin Portal</span>
            <a href="/admin/logout" class="logout-btn">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>
    </header>
    <div class="layout">

        <!-- overlay (same as dashboard) -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- SIDEBAR -->
        <aside class="sidebar" id="sidebar">
            <span class="sidebar-label">Main</span>
            <a class="nav-link " href="/admin/dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
            <a class="nav-link active" href="/admin/customer"><i class="bi bi-people"></i> Customers</a>
            <a class="nav-link" href="/admin/product"><i class="bi bi-box-seam"></i> Products</a>
            <a class="nav-link" href="/admin/orderManagement"><i class="bi bi-basket3"></i> Orders</a>

            <span class="sidebar-label">Management</span>
            <a class="nav-link" href="/admin/couponManagement"><i class="bi bi-ticket-perforated"></i> Coupons</a>
            <a class="nav-link" href="/admin/salesReport"><i class="bi bi-bar-chart-line"></i> Sales Report</a>
            <a class="nav-link" href="/admin/category"><i class="bi bi-tag"></i> Categories</a>
        </aside>
        <!-- MAIN -->
        <main class="main">

            <!-- SAME PAGE HEADER STYLE -->
            <div class="page-header">
                <h1 class="page-title">Customers</h1>
            </div>

            <div class="chart-card">
                <form action="/admin/customer" method="get" style="display:flex;gap:.5rem;">
                    <input type="text" name="search" placeholder="Search users..." value="<%= searchTerm %>"
                        style="flex:1;background:var(--surface2);border:1px solid var(--border);color:var(--cream);padding:.6rem;border-radius:6px;">

                    <button style="background:linear-gradient(135deg,var(--gold1),var(--gold2));
                        border:none;padding:.6rem .9rem;border-radius:6px;">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>

            <!--TABLE INSIDE SAME CARD STYLE -->
            <div class="chart-card">
                <h2 class="card-title">Customer List</h2>

                <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;margin-top:1rem;">
                        <thead>
                            <tr style="border-bottom:1px solid var(--border);">
                                <th style="padding:.75rem;color:var(--muted);font-size:.75rem;">Sr.no</th>
                                <th style="padding:.75rem;color:var(--muted);font-size:.75rem;">Name</th>
                                <th style="padding:.75rem;color:var(--muted);font-size:.75rem;">Email</th>
                                <th style="padding:.75rem;color:var(--muted);font-size:.75rem;">Mobile</th>
                                <th style="padding:.75rem;color:var(--muted);font-size:.75rem;">Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% if (users.length> 0) { %>
                                <% users.forEach((user,i)=>{ %>
                                    <tr style="border-bottom:1px solid var(--border);">

                                        <td data-label="Sr.no">
                                            <%= i+1 %>
                                        </td>

                                        <td data-label="Name">
                                            <%= user.firstName %>
                                        </td>

                                        <td data-label="Email">
                                            <%= user.email %>
                                        </td>

                                        <td data-label="Mobile">
                                            <%= user.mobile %>
                                        </td>

                                        <td data-label="Action">
                                            <% if(!user.isBlocked){ %>
                                                <a href="/admin/userStatus?id=<%=user._id%>" class="action-btn block">
                                                    Block
                                                </a>
                                                <% } else { %>
                                                    <a href="/admin/userStatus?id=<%=user._id%>"
                                                        class="action-btn unblock">
                                                        Unblock
                                                    </a>
                                                    <% } %>
                                        </td>

                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5"
                                                    style="padding:1rem;text-align:center;color:var(--dim);">
                                                    No users found
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </main>
    </div>

    <!--   SCRIPT -->
    <script>
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const hamburger = document.getElementById('hamburgerBtn');

        hamburger.addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });

        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        });
    </script>

</body>

</html>