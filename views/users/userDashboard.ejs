
<!-- header -->
<%- include('../Z_Common_Code/userDashboard/header.ejs') %>

<!-- navbar -->
<%- include('../Z_Common_Code/userDashboard/navbar.ejs') %>


<!-- Dashboard -->
<div class="container mt-4 mb-5">
    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-12 col-md-3">
            <!-- Mobile toggle -->
            <button class="sidebar-toggle collapsed d-md-none" data-bs-toggle="collapse" data-bs-target="#sidebarMenu"
                aria-expanded="false">
                Account Menu <i class="bi bi-chevron-down"></i>
            </button>

            <div class="collapse" id="sidebarMenu">
                <div class="list-group">
                    <h4 class="mb-2 mt-1 px-1">Account Info</h4>
                    <a href="/editProfile" class="list-group-item list-group-item-action">Update Profile</a>
                    <a href="/address" class="list-group-item list-group-item-action">Manage Address</a>
                    <a href="/order/history" class="list-group-item list-group-item-action">My Orders</a>
                    <a href="/user/wallet" class="list-group-item list-group-item-action">Wallet</a>
                    <h4 class="mt-4 mb-2 px-1">Personal</h4>
                    <a href="#" class="list-group-item list-group-item-action">Terms of Use</a>
                    <a href="#" class="list-group-item list-group-item-action">Privacy Policy</a>
                    <a href="/logout" class="list-group-item list-group-item-action">Logout</a>
                </div>
            </div>
        </div>

        <!-- Profile Content -->
        <div class="col-12 col-md-9">
            <div class="profile-card shadow-sm">
                <!-- Edit icon -->
                <div class="edit-icon">
                    <a href="/editProfile"><i class="bi bi-pencil-square fs-4"></i></a>
                </div>

                <div class="profile-body pt-2">
                    <img src="/imgs/profile_logo.png" alt="Profile picture">
                    <div class="profile-info">
                        <h4 class="text-uppercase mb-2">John Doe</h4>
                        <p><strong>Email:</strong> johndoe@example.com</p>
                        <p><strong>Mobile:</strong> +91 98765 43210</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Keep toggle chevron in sync with collapse state
    const toggleBtn = document.querySelector('.sidebar-toggle');
    const sidebarMenu = document.getElementById('sidebarMenu');
    if (sidebarMenu) {
        sidebarMenu.addEventListener('show.bs.collapse', () => toggleBtn.classList.remove('collapsed'));
        sidebarMenu.addEventListener('hide.bs.collapse', () => toggleBtn.classList.add('collapsed'));
    }
</script>
<!-- footer -->
    <%- include('../Z_Common_Code/userDashboard/footer.ejs') %>



