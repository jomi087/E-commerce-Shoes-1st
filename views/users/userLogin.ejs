<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fashion Feet – Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">
    <style>
        /* CURSOR FIX */
        * {
            cursor: default !important;
        }

        input,
        textarea,
        select,
        button,
        a {
            cursor: pointer !important;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"],
        input[type="search"] {
            cursor: text !important;
        }

        /* BASE */
        body {
            font-family: 'DM Sans', sans-serif;
            background: #0f0f0f;
            min-height: 100vh;
            margin: 0;
        }

        /* NAVBAR */
        .ff-navbar {
            background: #0f0f0f;
            border-bottom: 1px solid #222;
            padding: 0.75rem 1.5rem;
        }

        .ff-navbar .navbar-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.55rem;
            color: #f0e6d3 !important;
            letter-spacing: 1px;
            text-decoration: none;
        }

        .ff-navbar .nav-link {
            color: #999 !important;
            font-size: 0.78rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-weight: 500;
            padding: 0.4rem 3.6rem !important;
            transition: color 0.2s;
        }

        .ff-navbar .nav-link:hover {
            color: #f0e6d3 !important;
        }

        .ff-navbar .navbar-toggler {
            border-color: #333;
            color: #999;
        }

        .ff-navbar .navbar-toggler-icon {
            filter: invert(0.6);
        }

        /* SEARCH */
        .search-wrap {
            position: relative;
        }

        .search-wrap input {
            background: #111;
            border: 1px solid #333;
            border-radius: 8px 0 0 8px;
            color: #f0e6d3;
            font-size: 0.85rem;
            padding: 0.45rem 0.85rem;
            width: 180px;
            outline: none;
            transition: border-color 0.2s;
        }

        .search-wrap input::placeholder {
            color: #444;
        }

        .search-wrap input:focus {
            border-color: #c9a96e;
        }

        .search-wrap button {
            background: linear-gradient(135deg, #c9a96e, #a8813d);
            border: none;
            border-radius: 0 8px 8px 0;
            color: #0f0f0f;
            padding: 0.45rem 0.85rem;
            font-size: 0.9rem;
        }

        .search-wrap button:hover {
            opacity: 0.85;
        }

        /* NAV ICONS */
        .nav-icons a {
            color: #999 !important;
            font-size: 1.35rem;
            transition: color 0.2s;
        }

        .nav-icons a:hover {
            color: #c9a96e !important;
        }

        /* PAGE BG */
        .page-bg {
            background: #0f0f0f;
            min-height: calc(100vh - 64px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2.5rem 1rem;
        }

        /* LOGIN CARD */
        .login-card {
            background: #1a1a1a;
            border: 1px solid #2a2a2a;
            border-radius: 16px;
            padding: 2.5rem 2.75rem;
            width: 100%;
            max-width: 520px;
            box-shadow: 0 8px 48px rgba(0, 0, 0, 0.5);
            animation: fadeUp 0.4s ease both;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .login-card h2 {
            font-family: 'Playfair Display', serif;
            color: #f0e6d3;
            font-size: 1.8rem;
            margin-bottom: 0.2rem;
        }

        .login-card .subtitle {
            color: #666;
            font-size: 0.82rem;
            letter-spacing: 0.5px;
            margin-bottom: 1.75rem;
        }

        /* LABELS */
        .form-label {
            color: #999;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-weight: 500;
            margin-bottom: 0.4rem;
        }

        /* INPUTS */
        .form-control {
            background: #111 !important;
            border: 1px solid #333 !important;
            border-radius: 8px !important;
            color: #f0e6d3 !important;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            padding: 0.65rem 0.9rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-control:focus {
            border-color: #c9a96e !important;
            box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.12) !important;
            outline: none;
        }

        .form-control::placeholder {
            color: #444 !important;
        }

        /* FIELD ERROR */
        .field-err {
            font-size: 0.78rem;
            color: #e05f5f;
            display: block;
            min-height: 1.1rem;
            margin-top: 0.3rem;
        }

        /* SERVER ERROR */
        .server-error {
            font-size: 0.83rem;
            color: #e05f5f;
            text-align: center;
            margin-bottom: 1rem;
        }

        /* FORGOT */
        .forgot-link {
            font-size: 0.8rem;
            color: #c9a96e;
            text-decoration: none;
        }

        .forgot-link:hover {
            text-decoration: underline;
        }

        /* SUBMIT BTN */
        .btn-submit {
            background: linear-gradient(135deg, #c9a96e, #a8813d);
            border: none;
            border-radius: 10px;
            color: #0f0f0f;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
            font-size: 0.88rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 0.8rem;
            width: 100%;
            transition: opacity 0.2s, transform 0.15s;
        }

        .btn-submit:hover {
            opacity: 0.87;
            transform: translateY(-1px);
            color: #0f0f0f;
        }

        /* DIVIDER */
        .or-divider {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 1.25rem 0;
        }

        .or-divider span {
            color: #444;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .or-divider::before,
        .or-divider::after {
            content: '';
            flex: 1;
            border-top: 1px solid #2a2a2a;
        }

        /* GOOGLE BTN */
        .btn-google {
            background: #1e1e1e;
            border: 1px solid #333;
            border-radius: 10px;
            color: #f0e6d3;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.88rem;
            font-weight: 500;
            padding: 0.7rem;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
            transition: background 0.2s, border-color 0.2s;
        }

        .btn-google:hover {
            background: #252525;
            border-color: #c9a96e;
            color: #f0e6d3;
        }

        /* BOTTOM LINKS */
        .bottom-text {
            color: #666;
            font-size: 0.83rem;
            text-align: center;
            margin-top: 1.25rem;
            margin-bottom: 0;
        }

        .bottom-text a {
            color: #c9a96e;
            text-decoration: none;
            font-weight: 600;
        }

        .bottom-text a:hover {
            text-decoration: underline;
        }

        hr.card-divider {
            border: none;
            border-top: 1px solid #2a2a2a;
            margin: 1.25rem 0;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="ff-navbar navbar navbar-expand-lg">
        <div class="container">

            <!-- BRAND -->
            <a class="navbar-brand" href="/">Fashion-Feet</a>

            <!-- TOGGLER -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu"
                aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- MENU -->
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-4">
                    <li class="nav-item">
                        <a class="nav-link px-3" href="/shop">Shop</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link px-3" href="#">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link px-3" href="#">Contact</a>
                    </li>

                </ul>
            </div>

        </div>
    </nav>
    <!-- PAGE -->
    <div class="page-bg">
        <div class="login-card">

            <h2>Welcome back</h2>
            <p class="subtitle">Sign in to your Fashion Feet account</p>

            <!-- Server error (EJS) -->
            <p class="server-error">
                <%= locals.message %>
            </p>

            <form action="/login" method="post" onsubmit="return validateForm()" novalidate>

                <div class="mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <input type="email" class="form-control" name="email" id="email" placeholder="you@example.com">
                    <span id="email-error" class="field-err"></span>
                </div>

                <div class="mb-2">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" name="password" id="password"
                        placeholder="Enter your password">
                    <span id="password-error" class="field-err"></span>
                </div>

                <div class="text-end mb-3">
                    <a href="/forgetPassword" class="forgot-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn-submit">Sign In</button>
            </form>

            <div class="or-divider"><span>or continue with</span></div>

            <a href="/auth/google" class="btn-google">
                <svg width="18" height="18" viewBox="0 0 20 20">
                    <path
                        d="M16.51 8H8.98v3h4.3c-.18 1-.74 1.48-1.6 2.04v2.01h2.6a7.8 7.8 0 002.38-5.88c0-.57-.05-.66-.15-1.18z"
                        fill="#4285F4" />
                    <path d="M8.98 17c2.16 0 3.97-.72 5.3-1.94l-2.6-2a4.8 4.8 0 01-7.18-2.54H1.83v2.07A8 8 0 008.98 17z"
                        fill="#34A853" />
                    <path d="M4.5 10.52a4.8 4.8 0 010-3.04V5.41H1.83a8 8 0 000 7.18l2.67-2.07z" fill="#FBBC05" />
                    <path
                        d="M8.98 4.18c1.17 0 2.23.4 3.06 1.2l2.3-2.3A8 8 0 001.83 5.4L4.5 7.49a4.77 4.77 0 014.48-3.3z"
                        fill="#EA4335" />
                </svg>
                Continue with Google
            </a>

            <hr class="card-divider">
            <p class="bottom-text">Don't have an account? <a href="/signup">Create one</a></p>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function validateForm() {
            let isValid = true;

            let email = document.getElementById('email').value.trim();
            let password = document.getElementById('password').value.trim();
            let emailError = document.getElementById('email-error');
            let passwordError = document.getElementById('password-error');

            emailError.textContent = '';
            passwordError.textContent = '';

            if (!email) {
                emailError.textContent = 'Email is required.';
                isValid = false;
            } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                emailError.textContent = 'Invalid email format.';
                isValid = false;
            }

            if (!password) {
                passwordError.textContent = 'Password is required.';
                isValid = false;
            }

            return isValid;
        }
    </script>

</body>

</html>