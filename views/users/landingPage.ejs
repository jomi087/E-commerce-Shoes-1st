<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Fashion Feet</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <style>
        /* CURSOR FIX */
        * { cursor: default !important; }
        input, textarea, select, button, a { cursor: pointer !important; }
        input[type="search"], input[type="text"] { cursor: text !important; }

        /* BASE */
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: #0f0f0f;
            color: #f0e6d3;
            margin: 0;
        }

        /* ── NAVBAR ── */
        .ff-navbar {
            background: #0f0f0f;
            border-bottom: 1px solid #222;
            padding: 0.75rem 0;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .ff-navbar .navbar-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.55rem;
            color: #f0e6d3 !important;
            letter-spacing: 1px;
            text-decoration: none;
        }
        .ff-navbar .nav-link {
            color: #999 !important;
            font-size: 0.78rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-weight: 500;
            padding: 0.4rem 1.6rem !important;
            transition: color 0.2s;
        }
        .ff-navbar .nav-link:hover { color: #f0e6d3 !important; }
        .ff-navbar .navbar-toggler { border-color: #333; }
        .ff-navbar .navbar-toggler-icon { filter: invert(0.6); }

        /* Search */
        .search-wrap { display: flex; }
        .search-wrap input {
            background: #111;
            border: 1px solid #333;
            border-right: none;
            border-radius: 8px 0 0 8px;
            color: #f0e6d3;
            font-size: 0.85rem;
            padding: 0.45rem 0.85rem;
            width: 180px;
            outline: none;
            transition: border-color 0.2s;
        }
        .search-wrap input::placeholder { color: #444; }
        .search-wrap input:focus { border-color: #c9a96e; }
        .search-wrap button {
            background: linear-gradient(135deg, #c9a96e, #a8813d);
            border: none;
            border-radius: 0 8px 8px 0;
            color: #0f0f0f;
            padding: 0.45rem 0.9rem;
            font-size: 0.9rem;
            transition: opacity 0.2s;
        }
        .search-wrap button:hover { opacity: 0.85; }

        /* Nav icons */
        .nav-icons a {
            color: #999 !important;
            font-size: 1.3rem;
            transition: color 0.2s;
            text-decoration: none;
        }
        .nav-icons a:hover { color: #c9a96e !important; }
        .nav-icons .user-greeting {
            color: #c9a96e !important;
            font-size: 0.8rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-weight: 600;
            text-decoration: none;
        }
        .nav-icons .user-greeting:hover { color: #f0e6d3 !important; }

        /* ── CAROUSEL ── */
        #carouselBanner { border-radius: 0; overflow: hidden; }
        #carouselBanner img { max-height: 520px; object-fit: cover; width: 100%; }
        .carousel-control-prev-icon,
        .carousel-control-next-icon { filter: invert(1); }

        /* BRANDS */
        .brands-section {
            background: #111;
            border-top: 1px solid #1e1e1e;
            border-bottom: 1px solid #1e1e1e;
            padding: 2.5rem 0;
        }
        .brand-item {
            display: flex;
            align-items: center;
            justify-content: center;
            background: #1a1a1a;
            border: 1px solid #222;
            border-radius: 14px;
            padding: 2rem 2.5rem;
            height: 150px;
            transition: border-color 0.3s, background 0.3s;
            text-decoration: none;
        }
        .brand-item:hover {
            border-color: #c9a96e;
            background: #1e1e1e;
        }
        .brand-item img {
            max-height: 150px;
            max-width: 280px;
            width: 100%;
            object-fit: contain;
            filter: grayscale(100%) brightness(0.75);
            transition: filter 0.3s;
        }
        .brand-item:hover img {
            filter: grayscale(0%) brightness(1);
        }

        /* ── SECTION HEADING ── */
        .section-heading {
            font-family: 'Playfair Display', serif;
            color: #f0e6d3;
            font-size: 1.5rem;
            letter-spacing: 0.5px;
            margin-bottom: 0.25rem;
        }
        .section-sub {
            color: #666;
            font-size: 0.78rem;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        .gold-line {
            width: 48px;
            height: 2px;
            background: linear-gradient(135deg, #c9a96e, #a8813d);
            border-radius: 2px;
            margin: 0.6rem 0 2rem;
        }

        /* ── PRODUCT CARD ── */
        .product-card {
            background: #1a1a1a;
            border: 1px solid #222;
            border-radius: 12px;
            overflow: hidden;
            transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
            margin-bottom: 1.5rem;
        }
        .product-card:hover {
            border-color: #c9a96e;
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.4);
        }

        /* Image area */
        .product-img-wrap {
            position: relative;
            overflow: hidden;
            background: #111;
            aspect-ratio: 1 / 1;
        }
        .product-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: opacity 0.4s ease, transform 0.4s ease;
        }
        .product-img-wrap .hover-img {
            position: absolute;
            inset: 0;
            opacity: 0;
        }
        .product-card:hover .default-img { opacity: 0; transform: scale(1.04); }
        .product-card:hover .hover-img  { opacity: 1; transform: scale(1.04); }

        /* Card body */
        .product-body { padding: 0.9rem 1rem 1rem; }
        .product-category {
            font-size: 0.7rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #c9a96e;
            margin-bottom: 0.3rem;
        }
        .product-category a { color: inherit; text-decoration: none; }
        .product-name {
            font-size: 0.9rem;
            font-weight: 500;
            color: #f0e6d3;
            margin-bottom: 0.5rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .product-name a { color: inherit; text-decoration: none; }
        .product-name a:hover { color: #c9a96e; }

        /* Prices */
        .product-price-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .price-current {
            font-size: 1rem;
            font-weight: 600;
            color: #c9a96e;
        }
        .price-old {
            font-size: 0.8rem;
            color: #555;
            text-decoration: line-through;
            margin-left: 6px;
        }

        /* Wishlist button */
        .wish-btn {
            background: none;
            border: none;
            padding: 0;
            color: #555;
            font-size: 1.1rem;
            transition: color 0.2s, transform 0.2s;
            line-height: 1;
        }
        .wish-btn:hover { color: #e05f5f; transform: scale(1.2); }
        .wish-btn .bi-heart-fill { color: #e05f5f; }

        /* ── FOOTER ── */
        .ff-footer {
            background: #111;
            border-top: 1px solid #1e1e1e;
            padding: 3rem 0 1.5rem;
            margin-top: 4rem;
        }
        .ff-footer .footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            color: #f0e6d3;
            margin-bottom: 0.5rem;
        }
        .ff-footer .footer-tagline {
            color: #555;
            font-size: 0.8rem;
            letter-spacing: 1px;
        }
        .ff-footer .footer-heading {
            color: #f0e6d3;
            font-size: 0.75rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 1rem;
        }
        .ff-footer ul { list-style: none; padding: 0; margin: 0; }
        .ff-footer ul li { margin-bottom: 0.5rem; }
        .ff-footer ul li a {
            color: #666;
            font-size: 0.85rem;
            text-decoration: none;
            transition: color 0.2s;
        }
        .ff-footer ul li a:hover { color: #c9a96e; }
        .ff-footer .footer-divider {
            border: none;
            border-top: 1px solid #1e1e1e;
            margin: 2rem 0 1.25rem;
        }
        .ff-footer .footer-copy {
            color: #444;
            font-size: 0.78rem;
        }
        .ff-footer .footer-copy a { color: #c9a96e; text-decoration: none; }
        .ff-footer .payment-img {
            max-width: 200px;
            filter: grayscale(1) brightness(0.6);
            margin-top: 0.5rem;
        }
        .ff-footer .logo-img {
            max-height: 60px;
            filter: brightness(0.8);
        }
    </style>
</head>
<body>

<!-- ── NAVBAR ── -->
<nav class="ff-navbar navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="/">Fashion-Feet</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu"
            aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" href="/shop">Shop</a></li>
                <li class="nav-item"><a class="nav-link" href="#">About</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
            </ul>

            <div class="d-flex align-items-center gap-3">
                <form class="search-wrap" role="search" action="/" method="get">
                    <input type="search" placeholder="Search..." name="search" value="<%= searchTerm %>">
                    <button type="submit"><i class="bi bi-search"></i></button>
                </form>

                <div class="nav-icons d-flex align-items-center gap-3 ms-1">
                    <a href="/wishList"><i class="bi bi-heart"></i></a>
                    <a href="/cart"><i class="bi bi-cart"></i></a>
                    <% if (!locals.user) { %>
                        <a href="/login"><i class="bi bi-person-circle"></i></a>
                    <% } else { %>
                        <a class="user-greeting" href="/personalInfo">Hi, <%= user.firstName %></a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- ── CAROUSEL ── -->
<div id="carouselBanner" class="carousel slide" data-bs-ride="carousel" data-bs-interval="2000">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="/imgs/banner/banner2.jpg" class="d-block w-100" alt="Slide 1">
        </div>
        <div class="carousel-item">
            <img src="/imgs/banner/banner1.png" class="d-block w-100" alt="Slide 2">
        </div>
        <div class="carousel-item">
            <img src="/imgs/banner/banner4.png" class="d-block w-100" alt="Slide 3">
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselBanner" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselBanner" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<!-- ── BRANDS ── -->
<section class="brands-section">
    <div class="container">
        <div class="row g-3 justify-content-center">
            <div class="col-6 col-md-3">
                <a href="#" class="brand-item"><img src="/imgs/Brand/ADIDAS - LOGO.jpeg" alt="Adidas"></a>
            </div>
            <div class="col-6 col-md-3">
                <a href="#" class="brand-item"><img src="/imgs/Brand/Logo da Puma.jpeg" alt="Puma"></a>
            </div>
            <div class="col-6 col-md-3">
                <a href="#" class="brand-item"><img src="/imgs/Brand/Reebok logo.jpeg" alt="Reebok"></a>
            </div>
            <div class="col-6 col-md-3">
                <a href="#" class="brand-item"><img src="/imgs/Brand/NIKE LOGO.jpeg" alt="Nike"></a>
            </div>
        </div>
    </div>
</section>

<!-- ── PRODUCTS ── -->
<main>
    <section class="py-5">
        <div class="container">
            <p class="section-sub mb-1">Latest Arrivals</p>
            <h2 class="section-heading">New Added</h2>
            <div class="gold-line"></div>

            <div class="row">
                <% for (let i = 0; i < product.length; i++) { %>
                <div class="col-lg-3 col-md-4 col-sm-6 col-12">
                    <div class="product-card">
                        <div class="product-img-wrap">
                            <a href="/productDetails?id=<%= product[i]._id %>">
                                <img class="default-img" src="/imgs/product/<%= product[i].images[0] %>" alt="<%= product[i].productName %>">
                                <img class="hover-img"   src="/imgs/product/<%= product[i].images[1] %>" alt="<%= product[i].productName %>">
                            </a>
                        </div>
                        <div class="product-body">
                            <div class="product-category">
                                <a href="/productDetails?id=<%= product[i]._id %>"><%= product[i].category.name %></a>
                            </div>
                            <div class="product-name">
                                <a href="/productDetails?id=<%= product[i]._id %>"><%= product[i].productName %></a>
                            </div>
                            <div class="product-price-row">
                                <div class="d-flex align-items-baseline">
                                    <span class="price-current">
                                        <% if (product[i].OfferSalePrice) { %>
                                            ₹<%= product[i].OfferSalePrice %>
                                        <% } else { %>
                                            ₹<%= product[i].salePrice %>
                                        <% } %>
                                    </span>
                                    <span class="price-old">₹<%= product[i].regularPrice %></span>
                                </div>
                                <% if (!locals.user) { %>
                                    <button class="wish-btn" onclick="userLogin()">
                                        <i class="bi bi-heart wishList-btn-icon" data-product-id="<%= product[i]._id %>"></i>
                                    </button>
                                <% } else { %>
                                    <button class="wish-btn" onclick="wishlist('<%= product[i]._id %>')">
                                        <i class="bi bi-heart wishList-btn-icon" data-product-id="<%= product[i]._id %>"></i>
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </section>
</main>

<!-- ── FOOTER ── -->
<footer class="ff-footer">
    <div class="container">
        <div class="row g-4 justify-content-between">

            <div class="col-lg-3 col-md-6">
                <img class="logo-img mb-3" src="/imgs/Brand/JOMI.png" alt="JOMI">
                <p class="footer-tagline">Step into style with Fashion Feet — your destination for premium footwear.</p>
            </div>

            <div class="col-lg-2 col-md-3 col-6">
                <p class="footer-heading">About</p>
                <ul>
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms &amp; Conditions</a></li>
                </ul>
            </div>

            <div class="col-lg-2 col-md-3 col-6">
                <p class="footer-heading">Help</p>
                <ul>
                    <li><a href="#">Contact Us</a></li>
                </ul>
            </div>

            <div class="col-lg-3 col-md-6">
                <p class="footer-heading">Secured Payments</p>
                <img class="payment-img" src="/imgs/theme/payment-method.png" alt="Payment methods">
            </div>

        </div>

        <hr class="footer-divider">

        <div class="row">
            <div class="col-md-6">
                <p class="footer-copy mb-0">&copy; 2024 <strong style="color:#c9a96e">Fashion-Feet</strong> — E-commerce Website</p>
            </div>
            <div class="col-md-6 text-md-end">
                <p class="footer-copy mb-0">Designed by <a href="#">JOMI</a>. All rights reserved.</p>
            </div>
        </div>
    </div>
</footer>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
<script>
    let wishlistProducts = [];

    window.onload = async function () {
        const response = await fetch('/wishlist/check');
        const data = await response.json();
        wishlistProducts = data.productIdsInWishlist;
        updateHeartIcons();
    };

    function updateHeartIcons() {
        wishlistProducts.forEach(productId => {
            const icon = document.querySelector(`.wishList-btn-icon[data-product-id="${productId}"]`);
            if (icon) {
                icon.classList.remove('bi-heart');
                icon.classList.add('bi-heart-fill');
            }
        });
    }

    function userLogin() {
        window.location.href = "/login";
    }

    async function wishlist(productId) {
        try {
            const response = await fetch('/wishlist/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId })
            });
            const result = await response.json();

            if (result.success) {
                const icon = document.querySelector(`.wishList-btn-icon[data-product-id="${productId}"]`);
                const added = result.action === 'added';
                icon.classList.toggle('bi-heart', !added);
                icon.classList.toggle('bi-heart-fill', added);

                Swal.fire({
                    icon: 'success',
                    toast: true,
                    position: 'bottom',
                    width: 310,
                    background: '#1a1a1a',
                    color: '#f0e6d3',
                    customClass: { popup: 'swal2-custom-font' },
                    showConfirmButton: false,
                    timer: 2500,
                    text: added ? 'Added to Wishlist' : 'Removed from Wishlist'
                });
            } else {
                Swal.fire('Alert!', result.message || 'Error updating wishlist', 'error');
            }
        } catch (error) {
            Swal.fire({
                icon: 'error',
                toast: true,
                position: 'top-end',
                background: '#1a1a1a',
                color: '#f0e6d3',
                width: 300,
                text: 'Something went wrong. Please try again.',
                showConfirmButton: false,
                timer: 2000
            });
        }
    }
</script>
</body>
</html>